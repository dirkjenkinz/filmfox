    <Character Color="#FFFFFFFFFFFF" Name="Mr. Caxton! Open up! This is the police. Open up at once or I will be forced to break down your down.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="MR. CAXTON! OPEN UP! THIS IS THE POLICE. OPEN UP AT ONCE OR I WILL BE FORCED TO BREAK DOWN YOUR DOWN.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="MR. CAXTON! OPEN UP! THIS IS THE POLICE. OPEN UP AT ONCE OR I WILL BE FORCED TO BREAK DOWN YOUR DOWN." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Mr. Caxton! You are not in any trouble but if you do not open this door I will have no choice but to arrest you!'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="MR. CAXTON! YOU ARE NOT IN ANY TROUBLE BUT IF YOU DO NOT OPEN THIS DOOR I WILL HAVE NO CHOICE BUT TO ARREST YOU!'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="YT" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="For Chrissakes! Stop it will you!' After fumbling with the chain and nearly dislocated his thumb violently turning the latch the wrong way, Tom had the door open." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="FOR CHRISSAKES! STOP IT WILL YOU!' AFTER FUMBLING WITH THE CHAIN AND NEARLY DISLOCATED HIS THUMB VIOLENTLY TURNING THE LATCH THE WRONG WAY, TOM HAD THE DOOR OPEN." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Detective Inspector Warburg. Mind if I come in?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="DETECTIVE INSPECTOR WARBURG. MIND IF I COME IN?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="E" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="That the living room there, is it?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="THAT THE LIVING ROOM THERE, IS IT?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="CA" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="CAX" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="CAXT" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="CAXTO" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Well, I'm sure you had your reasons. I'm not here to judge you, Mr. Caxton. I'm here to find out about the man who was shot on your doorstep: a Mr. Joseph Miller. Did you know him?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="WELL, I'M SURE YOU HAD YOUR REASONS. I'M NOT HERE TO JUDGE YOU, MR. CAXTON. I'M HERE TO FIND OUT ABOUT THE MAN WHO WAS SHOT ON YOUR DOORSTEP: A MR. JOSEPH MILLER. DID YOU KNOW HIM?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Then can you explain why he came to your house when there was a curfew on?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="THEN CAN YOU EXPLAIN WHY HE CAME TO YOUR HOUSE WHEN THERE WAS A CURFEW ON?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="THEN CAN YOU EXPLAIN WHY HE CAME TO YOUR HOUSE WHEN THERE WAS A CURFEW ON?" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Any port in a storm, hey? I suppose that makes sense.' Warburg wet the end of his pencil with the tip of his tongue. 'Tell me what happened.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="ANY PORT IN A STORM, HEY? I SUPPOSE THAT MAKES SENSE.' WARBURG WET THE END OF HIS PENCIL WITH THE TIP OF HIS TONGUE. 'TELL ME WHAT HAPPENED.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="I really didn't see anything. I was sitting at the table over there playing Cluedo with my wife.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="I REALLY DIDN'T SEE ANYTHING. I WAS SITTING AT THE TABLE OVER THERE PLAYING CLUEDO WITH MY WIFE.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="I REALLY DIDN'T SEE ANYTHING. I WAS SITTING AT THE TABLE OVER THERE PLAYING CLUEDO WITH MY WIFE." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Yes. Judith, this is Detective Inspector Warburg. Detective Inspector Warburg - Judith.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="YES. JUDITH, THIS IS DETECTIVE INSPECTOR WARBURG. DETECTIVE INSPECTOR WARBURG - JUDITH.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="YES. JUDITH, THIS IS DETECTIVE INSPECTOR WARBURG. DETECTIVE INSPECTOR WARBURG - JUDITH." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Delighted to meet you, Mrs. Caxton.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="DELIGHTED TO MEET YOU, MRS. CAXTON.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="DELIGHTED TO MEET YOU, MRS. CAXTON." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="She's the reason I killed Mr. Kepler. He ate half her face. I don't know if you can tell.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="SHE'S THE REASON I KILLED MR. KEPLER. HE ATE HALF HER FACE. I DON'T KNOW IF YOU CAN TELL.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="It's not immediately obvious.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="IT'S NOT IMMEDIATELY OBVIOUS.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="IT'S NOT IMMEDIATELY OBVIOUS." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="I used papier-mache to fill in the missing bits.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="I USED PAPIER-MACHE TO FILL IN THE MISSING BITS.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="I USED PAPIER-MACHE TO FILL IN THE MISSING BITS." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Now, these soldiers - did they give any warnings before they shot Mr. Miller?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="NOW, THESE SOLDIERS - DID THEY GIVE ANY WARNINGS BEFORE THEY SHOT MR. MILLER?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="NOW, THESE SOLDIERS - DID THEY GIVE ANY WARNINGS BEFORE THEY SHOT MR. MILLER?" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Yes. I heard one of them shout Stop or we'll shoot.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="YES. I HEARD ONE OF THEM SHOUT STOP OR WE'LL SHOOT.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="YES. I HEARD ONE OF THEM SHOUT STOP OR WE'LL SHOOT." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="I'm always happy to help the police, Inspector.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="I'M ALWAYS HAPPY TO HELP THE POLICE, INSPECTOR.'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="I'M ALWAYS HAPPY TO HELP THE POLICE, INSPECTOR." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="When I get back to the station, I'll post you a compensation form. There's no reason for the army not to re-imburse you for your door. They could have dragged Mr. Miller out into the street before shooting him." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="WHEN I GET BACK TO THE STATION, I'LL POST YOU A COMPENSATION FORM. THERE'S NO REASON FOR THE ARMY NOT TO RE-IMBURSE YOU FOR YOUR DOOR. THEY COULD HAVE DRAGGED MR. MILLER OUT INTO THE STREET BEFORE SHOOTING HIM." Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="Perhaps you should consider a career change. Morticians are in huge demand right now.' Warburg leaned forward and sniffed at Judith's one good cheek, sampling its odour like as if it was the bouquet of a fine wine. 'Have you noticed how the dead smell different now?'" Visible="No"/>
    <Character Color="#FFFFFFFFFFFF" Name="PERHAPS YOU SHOULD CONSIDER A CAREER CHANGE. MORTICIANS ARE IN HUGE DEMAND RIGHT NOW.' WARBURG LEANED FORWARD AND SNIFFED AT JUDITH'S ONE GOOD CHEEK, SAMPLING ITS ODOUR LIKE AS IF IT WAS THE BOUQUET OF A FINE WINE. 'HAVE YOU NOTICED HOW THE DEAD SMELL DIFFERENT NOW?'" Visible="No"/>
