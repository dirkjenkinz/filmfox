<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>FilmFox</title>
        <link rel="stylesheet" href="../css/style.css">
        <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
        <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    </head>

    <body>
        <div class='container'>
            <div class='row'>
                <h1>Film Fox</h1>
            </div>
            <div class='row show'>
                <div class='col-md-4'></div>
                <div class='col-md-4'>
                    <button class='btn btn-block btn-edit' id='main'>Main Screen</button>
                </div>
            </div>
            <div class='row'>
             <table class='table-bordered table-sm table-dark table-grid' id='character_table'>
                     <thead>
                        <tr>
                            <th class='data-left'>API Key</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class='data-left'>
                                {{ api_key }}
                            </td>
                        </tr>
                    </tbody>
            </table>
            <table class='table-bordered table-sm table-dark table-grid' id='character_table'>
                    <thead>
                        <tr>
                            <th class='data-left'>Characters</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for i in range(1, characters.length, 6) -%}
                            <tr>
                                <td class='data-left'>{{characters[i]}}</td>
                                <td class='data-left'>{{characters[i + 1]}}</td>
                                <td class='data-left'>{{characters[i + 2]}}</td>
                                <td class='data-left'>{{characters[i + 3]}}</td>
                                <td class='data-left'>{{characters[i + 4]}}</td>
                                <td class='data-left'>{{characters[i + 5]}}</td>
                            </tr>
                        {%- endfor %}
                    </tbody>
                </table>
                <table class='table-bordered table-sm table-dark table-grid' id='script_table'>
                    <thead>
                        <tr>
                        <th class='data-left'>Scene</th>
                        <th class='data-left'>Character</th>
                        <th class='data-left'>Verbals</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for i in range(1, script.length) -%}
                            <tr>
                                <td class='data-left'>{{script[i][2]}}</td>
                                <td class='data-left'>{{script[i][0]}}</td>
                                <td class='data-left'>{{script[i][1]}}</td>
                            </tr>
                        {%- endfor %}
                    </tbody>
                </table>
            </div>
        </body>
        <script>
            $('#main').on('click', () => {
                window.location.href = `/`
            })
        </script>
    </html>