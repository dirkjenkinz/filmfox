{% extends "parent.njk" %}
{% block page %}
  <div class='row top'>
    <p hidden id='highest'>{{highest}}</p>
    <div class='col-md-1'>
      Note:
    </div>
    <div class='col-md-9' style='font-size: 80%;'>
      <input type="text" id="input-note" name="note" size='70' value='{{note}}'>
    </div>
    <div class='col-md-2'>
      <button type='button' class='btn btn-edit btn-block btn-sm btn-scene-shot-list' id='scene-shot-list_{{i}}' value='{{i}}'>
        Scene Shot List
      </button>
    </div>
  </div>
  <div class='row top'>
    <div class='col-md-1 hidden'>
      <audio id='master-play' style='width: 100%;'>
        <source src='' type='audio/mpeg'>
      </audio>
    </div>
    <div class='col-md-2'>
      {% if sceneNumber > 0 %}
        <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-previous' value='{{scene[0].scene}}'>
          Previous Scene
        </button>
        {% else %}
        <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-previous' value='{{scene[0].scene}}' disabled>
          Previous Scene
        </button>
      {% endif %}
    </div>
    <div class='col-md-4' style='font-size: 80%;'>
      Scene
      {{sceneNumber}}:
      {{scene[0].dialogue}}
    </div>
    <div class='col-md-4'></div>
    <div class='col-md-2'>
      {% if sceneNumber < highest -1  %}
        <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-next' value='{{scene[0].scene}}'>
          Next Scene
        </button>
      {% else %}
       <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-next' value='{{scene[0].scene}}' disabled>
          Next Scene
        </button>
      {% endif %}
    </div>
  </div>

  <div class='row tableFixHead' id='tabhead'>
    <div class='col-md-12'>
      <table id='script-table'>
        <tbody id='bod'>
          {% for i in range(0, scene.length) -%}
              <tr id='row_{{i}}' class='display-box'>
                <td class='non-header-display' style='width: 15%;'>
                  Character:
                  {{scene[i].character}}
                  <br><br>
                  Voice:<p id='voice_{{i}}'>{{scene[i].voice}}</p>
                </td>
                <td class='non-header-display' style='width:50%;'>{{scene[i].dialogue}}</td>
                <td class='non-header-display'>
                  <p style='font-size: 60%; color: black;'>{{scene[i].sound}}</p>
                  {% if (scene[i].voice == '-') or (scene[i].sound) %}
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-play' id='play_{{i}}' value='{{scene[i].sound}}'>
                      Play
                    </button>
                    <br>
                    <button class='btn btn-block btn-edit btn-sm btn-small btn-del' id='del_{{i}}' disabled='disabled' value='{{scene[i].sound}}'>
                      Delete
                    </button>
                  {% else %}
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-gen' id='gen_{{i}}' value='{{i}}' caller='{{display}}'>
                      Gen
                    </button>
                  {% endif %}
                  <br>
                  <p style='font-size: 60%; color: black;'>{{scene[i].duration}}
                </td>
                <td class='data-display card' style='width: 20%' id='crd_{{i}}'>
                  <button type='button' class='btn btn-edit btn-block btn-sm btn-change' id='change_{{i}}' value='{{i}}'>
                    Change Image
                  </button>
                  <br>
                  {% if scene[i].type === 'movie' %}
                    <video width='160' height='90' controls='controls' autoplay='autoplay' id='img_{{i}}' class='img' muted='muted'>
                      <source src='../data/{{title}}/images/{{scene[i].image}}' type='video/mp4'>
                    </video>
                  {% else %}
                    <img width='160' height='90' src='../data/{{title}}/images/{{scene[i].image}}' id='img_{{i}}' class='img' alt='{{scene[i].image}}'>
                  {% endif %}
                  <p style='font-size: 80%; color: white;'>
                    {{scene[i].image.substring(0,28)}}
                  </p>
                </td>
              </tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src='../js/parent.js'></script>
<script src='../js/display.js'></script>
{% endblock %}