<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>FilmFox</title>
        <link rel="stylesheet" href="../css/style.css">
        <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
        <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    </head>

    <body>
        <div class='container'>
            <div class='row'>
                <h1>Film Fox</h1>
            </div>
            <div class='row show'>
                <div class='col-md-4'></div>
                <div class='col-md-4'>
                    <button class='btn btn-block btn-edit' id='main'>Main Screen</button>
                </div>
            </div>
            <div class='row'>
                <table class='table-bordered table-sm table-dark table-grid' id='api_key_table'>
                     <thead>
                        <tr>
                            <th class='data-left'>API Key</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class='data-left'>
                                {{ api_key }}
                            </td>
                        </tr>
                    </tbody>
                </table>
                <table class='table-bordered table-sm table-dark table-grid' id='character_table'>
                    <thead>
                        <tr>
                            <th class='data-left' id='tab_ch_{{i}}'>Character</th>
                            <th class='data-left' id='tab_ch_{{i}}'>Voice</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for i in range(1, characters.length) -%}
                            <tr>
                                <td class='data-left'>{{characters[i]}}</td>
                                <td class='data-left'>
                                    <select name='sel_voices_${{i}}' id='voices'>
                                        {% for j in range(0, voice_data.length) -%}
                                            <option value="{{voice_data[j][2]}}">
                                                {{voice_data[j][0]}}
                                            </option>
                                        {%- endfor %}
                                    </select>
                                </td>
                            </tr>
                        {%- endfor %}
                    </tbody>
                </table>
                <table class='table-bordered table-sm table-dark table-grid' id='script_table'>
                    <thead>
                        <tr>
                        <th></th>
                        <th class='data-left'>Scene</th>
                        <th class='data-left'>Character</th>
                        <th class='data-left'>Verbals</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for i in range(0, 20) -%}
                            <tr>
                                <td class='data-left'>
                                     <button class='btn btn-block btn-edit btn-small btn-gen' id='gen_{{i}}'>Gen</button>
                                </td>
                                <td class='data-left'>{{script[i][2]}}</td>
                                <td class='data-left' id='ch_{{i}}'>{{script[i][0]}}</td>
                                <td class='data-left' id='vb_{{i}}'>{{script[i][1]}}</td>
                            </tr>
                        {%- endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <script>
            $('#main').on('click', () => {
                window.location.href = `/`
            }),
            $('.btn-gen').on('click', (e) => {
                let num = e.target.id.substring(4);
                let char = $('#ch_'+num)[0].textContent;
                let verbals =  $('#vb_'+num)[0].textContent;
                $('#character_table tr td:first-child').each(function (i, data)
                    {
  //                      console.log(i, data)
                    });
 //                   Query(".dname").find("td:eq(1)").text();
 //$('table tr.warning td:nth-child(2)').each(function(index, element)
                $('#character_table tr td:nth-child(2)').each(function (i, data)
                    {
                        console.log(i, data)
                    });
            });
        </script>
    </body>
</html>