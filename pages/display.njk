<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8'/>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'/>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'/>
    <title>FilmFox</title>
    <link rel='stylesheet' href='../css/style.css'/>
    <link rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'/>
    <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
  </head>
  <body>
    <div class='container-fluid'>
      <div class='row'>
        <div class='col-md-2'>
          <h4>Film Fox</h4>
        </div>
        <div class='col-md-1' hidden="hidden">
          <p id='ptr'>{{ptr}}</p>
          <p id='endpoint'>
          {{end}}
        </p>
      </div>
      <div class='col-md-3 data-right' id='title'>
        <h5>{{ title }}</h5>
      </div>
    </div>
    <div class='row show'>
      <div class='col-md-1'>
        <button class='btn btn-block btn-edit btn-sm' id='front'>
          Front
        </button>
      </div>
      <div class='col-md-1'>
        <button class='btn btn-block btn-edit btn-sm' id='ctv'>
          Voice Map&nbsp;&nbsp;
        </button>
      </div>
      <div class='col-md-1'>
        <button class='btn btn-block btn-edit btn-sm' id='srt'>SRT</button>
      </div>
      <div class='col-md-1'>
        <button class='btn btn-block btn-edit btn-sm' id='showreel'>Showreel&nbsp;</button>
      </div>
      <div class='col-md-3'></div>
      <div class='col-md-1 data-left'>
        <button class='btn btn-edit btn-sm' id='offset-minus'>
          -1 Second
        </button>
      </div>
      <div class='col-md-2 data-right show'>SRT offset in seconds:</div>
      <div class='col-md-1 show' id='offset'>{{offset}}</div>
      <div class='col-md-1 data-right'>
        <button class='btn btn-edit btn-sm' id='offset-plus'>
          +1 Second
        </button>
      </div>
    </div>
    <div class='row'>
      <div class='col-md-12 well'>
        <table class='table-bordered table-sm table-dark table-grid table-scroll' id='script_table'>
          <thead>
            <tr>
              <th class='t_pl'></th>
              <th class='data-left t_el'>Element/Scene</th>
              <th class='data-left t_ch'>Character</th>
              <th class='data-left t_vo'>Voice</th>
              <th class='data-left t_di' colspan='2'>Dialogue</th>
              <th class='data-left t_so'>Sound File</th>
              <th class='data-left t_ca'>Card</th>
            </tr>
          </thead>
          <tbody>
            {% for i in range(0, script.length) -%}
              {% if script[i] %}
                <tr>
                  <td class='data-left t_pl'>
                    {% if (script[i][3] == '-') or (script[i][4]) %}
                      <button class='btn btn-block btn-edit btn-sm btn-small btn-play' id="play_{{i}}" value='{{script[i][4]}}'>
                        Play
                      </button>
                    {% else %}
                      <button class=' btn="btn" btn-block="btn-block" btn-edit="btn-edit" btn-sm="btn-sm" btn-small="btn-small" btn-gen' id=' gen_{{i}}="gen_{{i}}" '>
                        Gen
                      </button>
                    {% endif %}
                  </td>
                  <td class='data-right t_el'>{{i}}/{{script[i][2]}}</td>
                  <td class='data-left t_ch'>{{script[i][0]}}</td>
                  <td class='data-left t_vo'>{{script[i][3]}}</td>
                  <td class='data-left t_di' colspan='2'>{{script[i][1]}}</td>
                  <td class='data-left t_so'>{{script[i][4].substring(0,16)}}
                    <br><br>
                    {% if (script[i][3] == '-') or (script[i][4]) %}
                      <button class='btn btn-block btn-edit btn-sm btn-small btn-del' id='del_{{i}}' value='{{script[i][0]}}'>
                        Delete
                      </button>
                    {% else %}
                      <button class='btn btn-block btn-edit btn-sm btn-small btn-del' id='del_{{i}}' disabled="disabled">
                        Delete
                      </button>
                    {% endif %}
                  </td>
                  <td class='data-left t_ca'>
                    {% if imageType[i + 1] === 'movie' %}
                      <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i}}" class="img" muted="muted">
                        <source src="../data/{{title}}/images/{{script[i}[5]}}" type="video/mp4">
                      </video>
                    {% else %}
                      <img width="160" height="90" src="../data/{{title}}/images/{{script[i][5]}}" id="img_{{i}}" class="img" alt="{{script[i][5]}}"/>
                    {% endif %}
                  </td>
                </tr>
              {% endif %}
            {%- endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script>
    $('#front').on('click', () => {
      window.location.href = `/`
    }),
    $('#ctv').on('click', () => {
      const f = $('#title')[0].innerText
      let ptr = $('#ptr')[0].innerText
      window.location.href = `/ctv?filmFoxFile=${f}&ptr=${ptr}`
    }),
    $('.btn-gen').on('click', (e) => {
      const num = e
        .target
        .id
        .substring(4)
      const f = $('#title')[0].innerText
      const ptr = $('#ptr')[0].innerText
      window.location.href = `/generate-single?filmFoxFile=${f}&element=${num}&ptr=${ptr}`
    }),
    $('.btn-play').on('click', (e) => {
      const f = $('#title')[0].innerText;
      const ptr = $('#ptr')[0].innerText;
      element = e.target.value;
      window.location.href = `/play?filmFoxFile=${f}&element=${element}&ptr=${ptr}`
    }),
    $('.btn-del').on('click', (e) => {
      const num = e
        .target
        .id
        .substring(4)
      const f = $('#title')[0].innerText
      const ptr = $('#ptr')[0].innerText
      const char = e.target.value
      window.location.href = `/delete?script=${f}&element=${num}&ptr=${ptr}&char=${char}`
    }),
    $('#offset-plus').on('click', () => {
      const f = $('#title')[0].innerText + '.fff'
      const ptr = $('#ptr')[0].innerText
      let offset = $('#offset')[0].innerText
      offset++
      window.location.href = `/offset?filmFoxFile=${f}&ptr=${ptr}&offset=${offset}`
    }),
    $('#offset-minus').on('click', () => {
      const f = $('#title')[0].innerText + '.fff'
      const ptr = $('#ptr')[0].innerText
      let offset = $('#offset')[0].innerText
      offset--
      if (offset < 0) 
        offset = 0
      window.location.href = `/offset?filmFoxFile=${f}&ptr=${ptr}&offset=${offset}`
    }),
    $('#srt').on('click', () => {
      const f = $('#title')[0].innerText
      let ptr = $('#ptr')[0].innerText
      let offset = $('#offset')[0].innerText;
      window.location.href = `/srt?title=${f}&ptr=${ptr}&offset=${offset}`
    }),
    $('#showreel').on('click', () => {
      const f = $('#title')[0].innerText
      let ptr = $('#ptr')[0].innerText
      let offset = $('#offset')[0].innerText;
      window.location.href = `/showreel?title=${f}&ptr=${ptr}&offset=${offset}`
    }),
    $('.img').on('click', (e) => {
      const f = $('#title')[0].innerText
      let ptr = $('#ptr')[0].innerText
      window.location.href = `/gallery?title=${f}&ptr=${ptr}&img=${e.target.id}`
    })
  </script>
</body>
</html>