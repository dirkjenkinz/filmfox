<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FilmFox</title>
    <link rel="stylesheet" href="../css/style.css" />
    <link
      rel="stylesheet"
      href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css"
    />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
  </head>

  <body>
    <div class="container-fluid">
      <div class="row">
        <div class="col-md-5">
          <h1>Film Fox</h1>
        </div>
        <div class="col-md-1">
          <p id="ptr">{{ptr}}</p>
          <p id="endpoint">{{end}}</p>
        </div>
        <div class="col-md-6 data-right" id="title"><h3>{{ title }}</h3></div>
      </div>
      <div class="row show">
        <div class="col-md-2">
          <button class="btn btn-block btn-edit" id="main">Main Screen</button>
        </div>
        <div class="col-md-2">
          <button class="btn btn-block btn-edit" id="ctv">
            Character To Voice
          </button>
        </div>
        <div class="col-md-1">
          <button class="btn btn-block btn-edit" id="plus-one">+1</button>
        </div>
        <div class="col-md-1">
          <button class="btn btn-block btn-edit" id="plus-ten">+10</button>
        </div>
        <div class="col-md-1">
          <button class="btn btn-block btn-edit" id="plus-one-hundred">
            +100
          </button>
        </div>
        <div class="col-md-1">
          <button class="btn btn-block btn-edit" id="end">End</button>
        </div>
        <div class="col-md-1">
          <button class="btn btn-block btn-edit" id="minus-one">-1</button>
        </div>
        <div class="col-md-1">
          <button class="btn btn-block btn-edit" id="minus-ten">-10</button>
        </div>
        <div class="col-md-1">
          <button class="btn btn-block btn-edit" id="minus-one-hundred">
            -100
          </button>
        </div>
        <div class="col-md-1">
          <button class="btn btn-block btn-edit" id="start">Start</button>
        </div>
      </div>
      <div class="row">
        <table
          class="table-bordered table-sm table-dark table-grid"
          id="script_table"
        >
          <thead>
            <tr>
              <th></th>
              <th class="data-left">Element</th>
              <th class="data-left">Scene</th>
              <th class="data-left">Character</th>
              <th class="data-left">Voice</th>
              <th class="data-left">Verbals</th>
            </tr>
          </thead>
          <tbody>
            {% for i in range(ptr, ptr + 10) -%}
            <tr>
              <td class="data-left">
                {% if script[i][3] == '-' %}
                <button
                  class="btn btn-block btn-edit btn-small btn-gen"
                  id="gen_{{i}}"
                  disabled
                >
                  Gen
                </button>
                {% else %}
                <button
                  class="btn btn-block btn-edit btn-small btn-gen"
                  id="gen_{{i}}"
                >
                  Gen
                </button>
                {% endif %}
              </td>
              <td class="data-right">{{i}}</td>
              <td class="data-right">{{script[i][2]}}</td>
              <td class="data-left" id="ch_{{i}}">{{script[i][0]}}</td>
              <td class="data-left" id="vc_{{i}}">{{script[i][3]}}</td>
              <td class="data-left" id="vb_{{i}}">{{script[i][1]}}</td>
            </tr>
            {%- endfor %}
          </tbody>
        </table>
      </div>
    </div>
    <script>
      $("#main").on("click", () => {
        window.location.href = `/`
      }),
        $("#ctv").on("click", () => {
          const f = $("#title")[0].innerText
          let ptr = $("#ptr")[0].innerText
          window.location.href = `/ctv?filmFoxFile=${f}&ptr=${ptr}`
        }),
        $("select").on("change", function (e) {
          let num = this.name.substring(7)
        }),
        $(".btn-gen").on("click", (e) => {
          const num = e.target.id.substring(4)
          const f = $("#title")[0].innerText
          window.location.href = `/generate-single?filmFoxFile=${f}&element=${num}`
        }),
        $("#plus-one").on("click", () => {
          const f = $("#title")[0].innerText + ".fff"
          let ptr = $("#ptr")[0].innerText;
          ptr++;
          window.location.href = `/display?filmFoxFile=${f}&ptr=${ptr}`
        }),
        $("#plus-ten").on("click", () => {
          const f = $("#title")[0].innerText + ".fff"
          let ptr = $("#ptr")[0].innerText
          ptr = parseInt(ptr) + 10
          window.location.href = `/display?filmFoxFile=${f}&ptr=${ptr}`
        }),
        $("#plus-one-hundred").on("click", () => {
          const f = $("#title")[0].innerText + ".fff"
          let ptr = $("#ptr")[0].innerText
          ptr = parseInt(ptr) + 100
          window.location.href = `/display?filmFoxFile=${f}&ptr=${ptr}`
        }),
        $("#minus-one").on("click", () => {
          const f = $("#title")[0].innerText + ".fff"
          let ptr = $("#ptr")[0].innerText
          ptr--
          window.location.href = `/display?filmFoxFile=${f}&ptr=${ptr}`
        }),
        $("#minus-ten").on("click", () => {
          const f = $("#title")[0].innerText + ".fff"
          let ptr = $("#ptr")[0].innerText
          ptr = ptr - 10
          window.location.href = `/display?filmFoxFile=${f}&ptr=${ptr}`
        }),
        $("#minus-one-hundred").on("click", () => {
          const f = $("#title")[0].innerText + ".fff"
          let ptr = $("#ptr")[0].innerText
          ptr = ptr - 100
          window.location.href = `/display?filmFoxFile=${f}&ptr=${ptr}`
        }),
        $("#start").on("click", () => {
          const f = $("#title")[0].innerText + ".fff"
          window.location.href = `/display?filmFoxFile=${f}&ptr=0`
        }),
        $("#end").on("click", () => {
          const f = $("#title")[0].innerText + ".fff"
          const ptr = $("#endpoint")[0].innerText
          window.location.href = `/display?filmFoxFile=${f}&ptr=${ptr}`
        })
    </script>
  </body>
</html>
