<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FilmFox</title>
    <link rel="stylesheet" href="../css/style.css" />
    <link
      rel="stylesheet"
      href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css"
    />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
  </head>

  <body>
    <div class="container-fluid">
      <div class="row">
        <div class="col-md-2">
          <h4>Film Fox</h4>
        </div>
        <div class="col-md-1" hidden>
          <p id="ptr">{{ptr}}</p>
          <p id="endpoint">{{end}}</p>
        </div>
        <div class="col-md-3 data-right" id="title"><h5>{{ title }}</h5></div>
        <div class='col-md-1'></div>
        <div class='col-md-4'>
          <button type='button' class='btn btn-edit btn-block btn-sm' onclick="history.back()">Go Back</button>
        </div>
      </div>
      <div class="row show">
        <div class="col-md-6">
          <table
            class="table-bordered table-sm table-dark table-grid"
            id="character_table"
          >
            <thead>
              <tr>
                <th class="data-left" id="tab_ch_{{i}}">Character</th>
                <th class="data-left" id="tab_vce_{{i}}">Voice</th>
              </tr>
            </thead>
            <tbody>
              {% for i in range(0, characters.length) -%}
              <tr>
                <td class="data-left" id="char_{{i}}">{{characters[i][0]}}</td>
                <td class="data-left">
                  <select name="voices_{{i}}" id="voices_{{i}}">
                    {% for j in range(0, voice_data.length) -%} {% if
                    characters[i][1] == voice_data[j][0] %}
                    <option value="{{voice_data[j][0]}}" selected>
                      {{voice_data[j][0]}}
                    </option>
                    {% else %}
                    <option value="{{voice_data[j][0]}}">
                      {{voice_data[j][0]}}
                    </option>
                    {% endif %} {%- endfor %}
                  </select>
                </td>
              </tr>
              {%- endfor %}
            </tbody>
          </table>
        </div>
        <div class="md-col-6">
          <table
            class="table-bordered table-sm table-dark table-grid"
            id="voice_table"
          >
            <thead>
              <tr>
                <th class="data-left" id="tab_voice_{{i}}">Voice</th>
                <th class="data-left" id="tab_description_{{i}}">
                  Description
                </th>
              </tr>
            </thead>
            <tbody>
              {% for i in range(1, voice_data.length) -%}
              <tr>
                <td class="data-left" id="voice_data_{{i}}">
                  {{voice_data[i][0]}}
                </td>
                <td class="data-left" id="voice_description_{{i}}">
                  {{voice_data[i][1]}}
                </td>
              </tr>
              {%- endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <!-- end container-fluid -->
    <script>
      $("#display").on("click", () => {
        const fff = $("#title")[0].outerText
        let ptr = $("#ptr")[0].innerText
        window.location.href = `/display?filmFoxFile=${fff}.fff&ptr=${ptr}`
      }),
        $("select").on("change", function (e) {
          const num = this.name.substring(7)
          const id = this.id
          const cid = `char_${num}`
          const voice = $(`#${id} option:selected`).text().trim()
          const character = $(`#${cid}`)[0].textContent
          const fff = $("#title")[0].outerText
          let ptr = $("#ptr")[0].innerText
          window.location.href = `/character-update?filmFoxFile=${fff}&character=${character}&voice=${voice}&ptr=${ptr}`
        })
    </script>
  </body>
</html>
