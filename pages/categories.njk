{% extends "parent.njk" %}
{% block page %}
  <div class='row top tableFixHead3' style='font-size: 90%;'>
    <div class='col-md-3'>
      <table id='table-categories'>
        <thead>
          <tr>
            <th>
              <input type="text" name="category" id='input-category' size='25'>
            </th>
            <th>
              <button type='button' class='btn-edit' id='btn-add-category' value=''>Add Category</button>
            </th>
          </tr>
        </thead>
        <tbody>
          {% for i in range(0, categories.length) -%}
            <tr>
              <td>
                {{categories[i]}}
              </td>
              <td>
                <button type='button' class='btn-edit btn-delete-category' value='{{categories[i]}}'>Delete</button>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  <script src='../js/parent.js'></script>
  <script src='../js/categories.js'></script>
{% endblock %}