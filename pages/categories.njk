{% extends "parent.njk" %}
{% block page %}
  <div class='row top' style='font-size: 90%;'>
    <div class='col-md-3 tableFixHead3'>
      <table id='table-categories'>
        <thead>
          <tr>
            <th colspan = '3'>
               <button type='button' class='btn-edit' id='btn-display-all'>Display All</button>
            </th>
          </tr>
          <tr>
            <th colspan='2'>
              <input type="text" name="category" id='input-category' size='25' style='border: 0;'>
            </th>
            <th>
              <button type='button' class='btn-edit' id='btn-add-category' value=''>Add</button>
            </th>
          </tr>
          <tr>
            <th colspan='3' style='font-size:50%;'>&nbsp;</th>
          </tr>
        </thead>
        <tbody>
          {% for i in range(0, categories.length) -%}
            <tr>
              <td>
                {{categories[i][0]}}
              </td>
              <td>
                {% if categories[i][1] === 'y' %}
                  <button type='button' class='btn-edit btn-display-category' value='{{categories[i][0]}}'>Display</button>
                {% else %}
                  &nbsp;
                {% endif %}
              </td>
              <td>
                {% if categories[i][1] === 'n' %}
                  <button type='button' class='btn-edit btn-delete-category' value='{{categories[i][0]}}'>Delete</button>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if category === '' %}
      <div class='col-md-9 tableFixHead3'>
        {% for i in range(0, list.length) -%}
          <p class='scene-breakdown'>
            {{list[i][0]}} --&nbsp;
            {% for j in range(1, list[i].length) -%}
              {% for k in range (0, list[i][j].length)%}
                {% if k === 0 %}
                  {{list[i][j][k]}}:
                {% else %}
                  {% if k < list[i][j].length - 1 %}
                    {{list[i][j][k]}},
                  {% else %}
                    {{list[i][j][k]}}&nbsp;&nbsp;
                  {% endif %}
                {% endif %}
              {% endfor %}
              ~&nbsp;
            {% endfor %}
          </p>
        {% endfor %}
      </div>
    {% else %}
      <div class='col-md-9 tableFixHead3'>
        <p class='display-header'>{{category}}</p>
        {% for i in range(0, displayList.length) -%}
          <p class='scene-breakdown'>
            {{displayList[i][0]}}
            --
            {% for j in range(1, displayList[i][1].length) -%}
              {{displayList[i][1][j]}},
            {% endfor %}
          </p>
        {% endfor %}
      </div>
    {% endif %}

  </div>
  <script src='../js/parent.js'></script>
  <script src='../js/categories.js'></script>
{% endblock %}