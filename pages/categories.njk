{% extends 'paperwork.njk' %}

{% block page %}
  <!-- Top row with buttons and input field -->
  <div class='row top' style='font-size: 90%;'>
    <!-- Left column with categories table -->
    <div class='col-md-3 tableFixHead3'>
      <table id='table-categories'>
        <thead>
          <!-- Button to display all categories -->
          <tr>
            <th colspan='3'>
               <button type='button' class='btn-edit' id='btn-display-all'>Display All</button>
            </th>
          </tr>
          <!-- Input field for adding a new category -->
          <tr>
            <th colspan='2'>
              <input type='text' name='category' id='input-category' size='25' style='border: 0;'>
            </th>
            <!-- Button to add a new category -->
            <th>
              <button type='button' class='btn-edit' id='btn-add-category' value=''>Add</button>
            </th>
          </tr>
          <!-- Spacer row -->
          <tr>
            <th colspan='3' style='font-size:50%;'>&nbsp;</th>
          </tr>
        </thead>
        <tbody>
          <!-- Loop through categories to display -->
          {% for category in categories %}
            <tr>
              <!-- Display category name -->
              <td>
                {{ category[0] }}
              </td>
              <!-- Display 'Display' button if category is marked as 'y' -->
              <td>
                {% if category[1] === 'y' %}
                  <button type='button' class='btn-edit btn-display-category' value='{{ category[0] }}'>Display</button>
                {% else %}
                  &nbsp;
                {% endif %}
              </td>
              <!-- Display 'Delete' button if category is marked as 'n' -->
              <td>
                {% if category[1] === 'n' %}
                  <button type='button' class='btn-edit btn-delete-category' value='{{ category[0] }}'>Delete</button>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <!-- Right column with scene breakdowns -->
    {% if category === '' %}
      <!-- Display all scene breakdowns -->
      <div class='col-md-9 tableFixHead3'>
        {% for scene in list %}
          <!-- Display scene breakdown -->
          <p class='scene-breakdown'>
            {{ scene[0] }} --&nbsp;
            {% for detailList in scene[1:] %}
              {% for detail in detailList %}
                <!-- Display breakdown details -->
                {{ detail }}{% if not loop.last %},{% endif %}
              {% endfor %}
              ~&nbsp;
            {% endfor %}
          </p>
        {% endfor %}
      </div>
    {% else %}
      <!-- Display selected category's breakdowns -->
      <div class='col-md-9 tableFixHead3'>
        <p class='display-header'>{{ category }}</p>
        {% for scene in displayList %}
          <!-- Display breakdown for the selected category -->
          <p class='scene-breakdown'>
            {{ scene[0] }} --
            {% for detail in scene[1][1:] %}
              {{ detail }}{% if not loop.last %},{% endif %}
            {% endfor %}
          </p>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- Include JavaScript files -->
  <script src='../js/paperwork.js'></script>
  <script src='../js/categories.js'></script>
{% endblock %}
