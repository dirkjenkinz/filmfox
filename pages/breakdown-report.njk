{% extends "parent.njk" %}
{% block page %}

  <div class='row'>
    <tr>
      <td colspan='4' style='color: white;'>
        &nbsp;&nbsp;<b>SCENE:
          <span id="output">{{sceneNumber}}:-
            {{scene[0].dialogue}}</span></b>
      </td>
    </tr>
    <div class='col-md-12 slidecontainer'>
      <input type="range" min="0" max="{{size}}" value="{{sceneNumber}}" id='slider-scene'>
    </div>
    <br><br>
  </div>

  <div class='row top'>
    <div class='col-md-2'>
      {% if sceneNumber > 0 %}
        <button class='btn btn-block btn-edit btn-sm' id='btn-previous'>Previous Scene</button>
      {% else %}
        <button class='btn btn-block btn-edit btn-sm' id='btn-previous' disabled="disabled">Previous Scene</button>
      {% endif %}
    </div>
    <div class='col-md-4'></div>
    <div class='col-md-2'>
      {% if sceneNumber < size %}
        <button class='btn btn-block btn-edit btn-sm' id='btn-next'>Next Scene</button>
      {% else %}
        <button class='btn btn-block btn-edit btn-sm' id='btn-next' disabled="disabled">Next Scene</button>
      {% endif %}
    </div>
    <div class='col-md-2'></div>
    <div class='col-md-2'>
      {% if exists == 'no' %}
        <button class='btn btn-block btn-edit btn-sm' id='btn-pdf'>Create PDF</button>
      {% else %}
        <button class='btn btn-block btn-edit btn-sm' id='btn-pdf'>Update PDF</button>
      {% endif %}
    </div>
  </div>
  <div class='row top' style='background: white;'>
    <p id='size' hidden="hidden">{{size}}</p>
    <div class='row tableFixHead' id='tabhead'>
      <div class='col-md-12'>
        <table id='table-header' style='background: black;'>
          <tbody>
            {% for i in range(0, breakdown.length) -%}
              <tr>
                <th width='20%'>
                  {{breakdown[i][0]}}
                </th>
                <td>
                  {% for j in range(1, breakdown[i].length) -%}
                    {% if j === breakdown[i].length - 1 %}
                      {{breakdown[i][j]}}
                    {% else %}
                      {{breakdown[i][j]}},&nbsp;
                    {% endif %}
                  {% endfor %}
                </td>
              </tr>
            {% endfor %}
          </body>
        </table>
      </div>
    </div>
  </div>
  <script src='../js/parent.js'></script>
  <script src='../js/breakdown-report.js'></script>
{% endblock %}