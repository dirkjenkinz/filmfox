<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8'/>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'/>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'/>
    <title>FilmFox</title>
    <link rel='stylesheet' href='../css/style.css'/>
    <link rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'/>
    <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
  </head>

  <body>
    <div class='container-fluid'>
      <div class='row'>
        <div class='col-md-2'>
          <h4>Film Fox</h4>
        </div>
        <div class='col-md-1' hidden="hidden">
          <p id='ptr'>{{ptr}}</p>
          <p id='img'>{{img}}</p>
        </div>
        <div class='col-md-3 data-right' id='title'>
          <h5>{{ title }}</h5>
        </div>
      </div>
      <div class='row show'>
        <div class='col-md-6'>
          <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
            <tbody>
              {% for i in range(0, unused.length, 3) -%}
                <tr>
                  <td class='data-left'>
                    {% if unused[i][1] === 'movie' %}
                      <video width="160" height="90" controls="controls" autoplay="autoplay" muted="muted" id="img_{{i}}" class="img">
                        <source src="../data/{{title}}/images/{{unused[i][0]}}" type="video/mp4">
                      </video>
                    {% else %}
                      <img width="160" height="90" src="../data/{{title}}/images/{{unused[i][0]}}" id="img_{{i}}" class="img" alt="unused[i][0]" value="{{unused[i][0]}}"/>
                    {% endif %}
                  </td>

                  {% if unused[i + 1][0] %}
                    <td class='data-left'>
                      {% if unused[i + 1][1] === 'movie' %}
                        <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i + 1}}" class="img" muted="muted">
                          <source src="../data/{{title}}/images/{{used[i +1][0]}}" type="video/mp4">
                        </video>
                      {% else %}
                        <img width="160" height="90" src="../data/{{title}}/images/{{unused[i + 1][0]}}" id="img_{{i + 1}}" class="img" alt="unused[i +1][0]"/>
                      {% endif %}
                    </td>
                  {% endif %}

                  {% if unused[i + 2][0] %}
                    <td class='data-left'>
                      {% if unused[i + 2][1] === 'movie' %}
                        <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i + 2}}" class="img" muted="muted">
                          <source src="../data/{{title}}/images/{{unused[i +2][0]}}" type="video/mp4">
                        </video>
                      {% else %}
                        <img width="160" height="90" src="../data/{{title}}/images/{{unused[i + 2][0]}}" id="img_{{i + 2}}" class="img" alt="unused[i +2][0]"/>
                      {% endif %}
                    </td>
                  {% endif %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        <div class='col-md-6'>
          <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
            <tbody>
              {% for i in range(0, used.length, 3) -%}
                <tr>
                  <td class='data-left'>
                    {% if used[i][1] === 'movie' %}
                      <video width="160" height="90" controls="controls" autoplay="autoplay" muted="muted" id="img_{{i}}" class="img">
                        <source src="../data/{{title}}/images/{{used[i][0]}}" type="video/mp4">
                      </video>
                    {% else %}
                      <img width="160" height="90" src="../data/{{title}}/images/{{used[i][0]}}" id="img_{{i}}" class="img" alt="used[i][0]" value="{{used[i][0]}}"/>
                    {% endif %}
                  </td>

                  {% if used[i + 1][0] %}
                    <td class='data-left'>
                      {% if used[i + 1][1] === 'movie' %}
                        <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i + 1}}" class="img" muted="muted">
                          <source src="../data/{{title}}/images/{{used[i +1][0]}}" type="video/mp4">
                        </video>
                      {% else %}
                        <img width="160" height="90" src="../data/{{title}}/images/{{used[i + 1][0]}}" id="img_{{i + 1}}" class="img" alt="used[i +1][0]"/>
                      {% endif %}
                    </td>
                  {% endif %}

                  {% if used[i + 2][0] %}
                    <td class='data-left'>
                      {% if used[i + 2][1] === 'movie' %}
                        <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i + 2}}" class="img" muted="muted">
                          <source src="../data/{{title}}/images/{{used[i +2][0]}}" type="video/mp4">
                        </video>
                      {% else %}
                        <img width="160" height="90" src="../data/{{title}}/images/{{used[i + 2][0]}}" id="img_{{i + 2}}" class="img" alt="used[i +2][0]"/>
                      {% endif %}
                    </td>
                  {% endif %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <script>
      $('.img').on('click', (e) => {
        const f = $('#title')[0].innerText
        const ptr = $('#ptr')[0].innerText
        const i = $('#img')[0].innerText;
        num = e
          .target
          .id
          .substring(4);
        window.location.href = `/update-image?title=${f}&ptr=${ptr}&img=${i}&num=${num}`
      })
    </script>
  </body>
</html>