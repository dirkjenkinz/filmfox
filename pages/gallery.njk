<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8'/>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'/>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'/>
    <title>FilmFox</title>
    <link rel='stylesheet' href='../css/style.css'/>
    <link rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'/>
    <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
  </head>

  <body>
    <div class='container-fluid'>
      <div class='row top'>
        <div class='col-md-2'>
          <h4>Film Fox</h4>
        </div>
        <div class='col-md-1' hidden="hidden">
          <p id='ptr'>{{ptr}}</p>
          <p id='element'>{{element}}</p>
          <p id='headersOnly'>{{headersOnly}}</p>
        </div>
        <div class='col-md-3 data-right' id='title'>
          <h5>{{ title }}</h5>
        </div>
        <div class='col-md-1'></div>
        <div class='col-md-4'>
          <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-back'>Go Back</button>
        </div>
      </div>
      <div class='row show'>
        <div class='col-md-6'>
          <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
            <tbody>
              {% for i in range(0, unused.length, 3) -%}
                <tr>
                {% for num in range(0, 3) -%}
                  {% if unused[i + num][0] %}
                    <td class='data-left'>
                      {% if unused[i + num][1] === 'movie' %}
                        <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i + num}}" class="img" muted="muted">
                          <source src="../data/{{title}}/images/{{unused[i + num][0]}}" type="video/mp4">
                        </video>
                      {% else %}
                        <img width="160" height="90" src="../data/{{title}}/images/{{unused[i + num][0]}}" id="img_{{i + num}}" class="img" alt="unused[i + num][0]"/>
                      {% endif %}
                      <button type='button' class='btn btn-edit btn-block btn-sm btn-select' value="{{unused[i + num][0]}}">
                        Select
                      </button>
                    </td>
                  {% endif %}
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        <div class='col-md-6'>
          <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
            <tbody>
              {% for i in range(0, used.length, 3) -%}
                <tr>
                {% for num in range(0, 3) -%}
                  {% if used[i + num][0] %}
                    <td class='data-left'>
                      {% if used[i + num][1] === 'movie' %}
                        <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i + num}}" class="img" muted="muted">
                          <source src="../data/{{title}}/images/{{used[i + num][0]}}" type="video/mp4">
                        </video>
                      {% else %}
                        <img width="160" height="90" src="../data/{{title}}/images/{{used[i + num][0]}}" id="img_{{i + num}}" class="img" alt="used[i + num][0]"/>
                      {% endif %}
                      <button type='button' class='btn btn-edit btn-block btn-sm btn-select' value="{{used[i + num][0]}}">
                        Select
                      </button>
                    </td>
                  {% endif %}
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <script src='../js/gallery.js'>
    </script>
  </body>
</html>