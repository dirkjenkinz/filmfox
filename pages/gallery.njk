{% extends "parent.njk" %}
{% block page %}
  <div class='row tableFixHead' id='tabhead'>
    <div class='col-md-6'>
      <p id='element' hidden="hidden">{{element}}</p>
      <p id='caller' hidden="hidden">{{caller}}</p>
      <p id='scene' hidden="hidden">{{scene}}</p>
      <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
        <tbody>
          {% for i in range(0, unused.length, 3) -%}
            <tr>
              {% for num in range(0, 3) -%}
                {% if unused[i + num][0] %}
                  <td class='data-left'>
                    {% if unused[i + num][1] === 'movie' %}
                      <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i + num}}" class="img" muted="muted">
                        <source src="../data/{{title}}/images/{{unused[i + num][0]}}" type="video/mp4">
                      </video>
                    {% else %}
                      <img width="160" height="90" src="../data/{{title}}/images/{{unused[i + num][0]}}" id="img_{{i + num}}" class="img" alt="unused[i + num][0]"/>
                    {% endif %}
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-select' value="{{unused[i + num][0]}}">
                      Select
                    </button>
                    <p style='font-size: 80%;'>
                      {{unused[i + num][0].substring(0,28)}}
                    </p>
                  </td>
                {% endif %}
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class='col-md-6'>
      <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
        <tbody>
          {% for i in range(0, used.length, 3) -%}
            <tr>
              {% for num in range(0, 3) -%}
                {% if used[i + num][0] %}
                  <td class='data-left'>
                    {% if used[i + num][1] === 'movie' %}
                      <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i + num}}" class="img" muted="muted">
                        <source src="../data/{{title}}/images/{{used[i + num][0]}}" type="video/mp4">
                      </video>
                    {% else %}
                      <img width="160" height="90" src="../data/{{title}}/images/{{used[i + num][0]}}" id="img_{{i + num}}" class="img" alt="used[i + num][0]"/>
                    {% endif %}
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-select' value="{{used[i + num][0]}}">
                      Select
                    </button>
                    <p style='font-size: 80%;'>
                      {{used[i + num][0].substring(0,28)}}
                    </p>
                  </td>
                {% endif %}
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src='../js/parent.js'></script>
<script src='../js/gallery.js'></script>
{% endblock %}