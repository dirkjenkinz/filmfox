{% extends 'parent.njk' %}
{% block page %}
  <div class='row'>
    <div class='col-md-8'>
      <input type='text' id='search' name='search' size='20' value='{{searchString}}'>
      Search
    </div>
    <div class='col-md-4' style='margin-top: 4px;'>
      <button type='button' class='btn btn-prevnext btn-block btn-sm btn-cancel'>Cancel & Go Back</button>
    </div>
  </div>
  <div class='row'>
    <div class='col-md-6' style='text-align: center; background:green; padding:6px; border: black 6px solid;'>UNUSED IMAGES</div>
    <div class='col-md-6' style='text-align: center; background:green; padding:6px; border: black 6px solid;'>USED IMAGES</div>
  </div>
  <div class='row tableFixHead' id='tabhead'>
    <div class='col-md-6'>
      <p id='caller' hidden='hidden'>{{caller}}</p>
      <p id='used-size' hidden>{{used.length}}</p>
      <p id='unused-size' hidden>{{unused.length}}</p>
      
      <table class='table-bordered table-sm table-dark table-grid' id='tab_img_unused'>
        <tbody id='tblBody1'>
          {% for i in range(0, unused.length, 2) -%}
            <tr id='unused-{{i}}' class='unused-item'>
              {% for num in range(0, 2) -%}
                {% if unused[i + num][0] %}
                  <td class='data-left' id='unused-image-{{i + num}}'>
                    {% if unused[i + num][1] === 'movie' %}
                      <video width='240' height='135' controls='controls' autoplay='autoplay' id='img_{{i + num}}' class='img' muted='muted'>
                        <source src='../data/{{title}}/images/{{unused[i + num][0]}}' type='video/mp4'>
                      </video>
                    {% else %}
                      <img width='240' height='135' src='../data/{{title}}/images/{{unused[i + num][0]}}' id='img_{{i + num}}' class='img' alt='unused[i + num][0]'>
                    {% endif %}
                  </td>
                {% endif %}
              {% endfor %}
            </tr>
            <tr class='unused-select'>
              {% for num in range(0, 2) -%}
                {% if unused[i + num][0] %}
                  <td class='data-left' id='unused-sel-{{i + num}}'>
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-select' id='btn-unused-{{i + num}}' value='{{unused[i + num][0]}}'>
                      Select
                    </button>
                    <p style='font-size: 60%;'>
                      {{unused[i + num][0].substring(0,28)}}
                    </p>
                  </td>
                {% endif %}
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class='col-md-6'>
      <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
        <tbody id='tblBody2'>
        {% for i in range(0, used.length, 2) -%}
            <tr id='used-{{i}}' class='used-item'>
              {% for num in range(0, 2) -%}
                {% if used[i + num][0] %}
                  <td class='data-left' id='used-image-{{i + num}}'>
                    {% if used[i + num][1] === 'movie' %}
                      <video width='240' height='135' controls='controls' autoplay='autoplay' id='img_{{i + num}}' class='img' muted='muted'>
                        <source src='../data/{{title}}/images/{{used[i + num][0]}}' type='video/mp4'>
                      </video>
                    {% else %}
                      <img width='240' height='135' src='../data/{{title}}/images/{{used[i + num][0]}}' id='img_{{i + num}}' class='img' alt='used[i + num][0]'>
                    {% endif %}
                  </td>
                {% endif %}
              {% endfor %}
            </tr>
            <tr class='used-select'>
              {% for num in range(0, 2) -%}
                {% if used[i + num][0] %}
                  <td class='data-left' id='used-sel-{{i + num}}'>
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-select' id='btn-used-{{i + num}}' value='{{used[i + num][0]}}'>
                      Select
                    </button>
                    <p style='font-size: 60%;'>
                      {{used[i + num][0].substring(0,28)}}
                    </p>
                  </td>
                {% endif %}
              {% endfor %}
            </tr>
                      {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src='../js/parent.js'></script>
<script src='../js/gallery.js'></script>
{% endblock %}