
      <div class='row show'>
        <div class='col-md-12'>
          <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
            <tbody>
              {% for i in range(0, package.length, 5) -%}
                <tr>
                  {% for num in range(0, 5) -%}
                    {% if  (package[i + num]) %}
                    <td class='data-left'>
                      Scene
                      {{i + num}}
                    </td>
                    <td class='data-left'>
                      {% if package[i + num][0][1] == 'movie' %}
                        <video width="80" height="45" controls="controls" autoplay="autoplay" muted="muted" class="img">
                          <source src="../data/{{title}}/images/{{package[i + num][0][0]}}" type="video/mp4">
                        </video>
                      {% else %}
                        <img width="80" height="45" src="../data/{{title}}/images/{{package[i + num][0][0]}}" class="img" alt="img_{{i}}"/>
                      {% endif %}
                    </td>
                    <td class='data-left'>
                      {% if gen[i + num ] == 'no' %}
                        <button class='btn btn-block btn-edit btn-sm btn-generate' value="{{i + num}}" id='btn-generate_{{i + num}}'>Generate</button>
                      {% else %}
                        <button class='btn btn-block btn-modify btn-sm btn-generate' value="{{i + num}}" id='btn-generate_{{i + num}}'>Modify</button>
                      {% endif %}
                    </td>
                    <td style='background:black;'>&nbsp;&nbsp;</td>
                    {% endif %}
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
<script src='../js/header.js'></script>
  <script>
    $('.btn-generate').on('click', (e) => {
      const title = $('#title')[0].innerText;
      const sceneNumber = $('#sceneNumber')[0].innerText;
      scene = e.target.value;
      window.location.href = `/create-video?title=${title}&sceneNumber=${sceneNumber}&scene=${scene}`
    })
    $('#btn-back').on('click', () => {
      const title = $('#title')[0].innerText;
      const sceneNumber = $('#sceneNumber')[0].innerText;
      window.location.href = `/display?title=${title}&sceneNumber=${sceneNumber}`;
    })
  </script>
{%endblock%}