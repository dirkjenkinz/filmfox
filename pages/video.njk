<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8'/>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'/>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'/>
    <title>FilmFox</title>
    <link rel='stylesheet' href='../css/style.css'/>
    <link rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'/>
    <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
  </head>

  <body>
    <div class='container-fluid'>
      <div class='row top'>
        <div class='col-md-2'>
          <h4>Film Fox</h4>
        </div>
        <div class='col-md-1' hidden="hidden">
          <p id='ptr'>{{ptr}}</p>
        </div>
        <div class='col-md-3 data-right' id='title'>
          <h5>{{ title }}</h5>
        </div>
        <div class='col-md-1'></div>
        <div class='col-md-2'>
          <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-back'>Go Back</button>
        </div>
      </div>
      <div class='row show'>
        <div class='col-md-12'>
          <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
            <tbody>
              {% for i in range(0, imageList.length, 4) -%}
                <tr>
                  {% for num in range(0, 4) -%}
                    {% if (i + num) < imageList.length %}
                      <td class='data-right'>
                        {{i + num}}
                      </td>
                      <td class='data-left'>
                        {% if imageList[i + num][1] === 'movie' %}
                          <video width="80" height="45" controls="controls" autoplay="autoplay" muted="muted" id="img_{{i + num}}" class="img">
                            <source src="../data/{{title}}/images/{{imageList[i + 1][0]}}" type="video/mp4">
                          </video>
                        {% else %}
                          <img width="80" height="45" src="../data/{{title}}/images/{{imageList[i + num][0]}}" id="img_{{i + num}}" class="img" alt="{{imageList[i][0]}}"/>
                        {% endif %}
                      </td>
                      <td class='data-right' id='times_{{i + num}}'>
                        {{times[i + num]}}
                      </td>
                      <td class='data-left'>
                        {% if imageList[i + num][2] == 'no' %}
                          <button class='btn btn-block btn-edit btn-sm btn-generate' value="{{imageList[i +num][0]}}" id='btn-generate_{{i + num}}'>Generate</button>
                        {% else %}
                          <button class='btn btn-block btn-modify btn-sm btn-generate' value="{{imageList[i +num][0]}}" id='btn-generate_{{i + num}}'>Modify</button>
                        {% endif %}
                      </td>
                    {% endif %}
                    <td style='width: 10px;'></td>
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <script>
    $('.btn-generate').on('click', (e) => {
      const title = $('#title')[0].innerText;
      const ptr = $('#ptr')[0].innerText;
      const img = e.target.value;
      const num = e
        .target
        .id
        .substring(13);
      const dur = $(`#times_${num}`)[0].innerText;
         window.location.href = `/create-video?title=${title}&ptr=${ptr}&img=${img}&dur=${dur}&num=${num}`
    })
    $('#btn-back').on('click', () => {
      const title = $('#title')[0].innerText;
      const ptr = $('#ptr')[0].innerText;
      window.location.href = `/display?title=${title}&ptr=${ptr}`;
    })
  </script>
</body>
</html>