{% extends "parent.njk" %}
{% block page %}
  <div class='row top'>
  <div class='col-md-6'>
    <button class='btn btn-edit' id='btn-concatenate-video'>Create Master</button>
    </div>
    <div class='col-md-6'>
    <button class='btn btn-edit' id='btn-create-powerpoint'>Create Powerpoint</button>
    </div>
  </div>
  <div class='row tableFixHead3' id='tabhead'>
    <div class='col-md-12'>
      <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
        <tbody>
          {% for i in range(0, script.length, 7) -%}
            <tr>
              {% for num in range(0, 7) -%}
                {% set cl = 'blue-box' %}
                {% if (script[i + num]) %}
                  <td class='{{cl}}'>
                    {% if complete[i + num] === 'yes' %}
                      {% if gen[i + num] === 'no' %}
                        <button class='btn btn-block btn-sm btn-generate' value="{{i + num}}" id='btn-generate_{{i + num}}'>Generate<br>Scene
                          {{i + num}}</button>
                      {% else %}
                        <button class='btn btn-block btn-modify btn-sm' value="{{i + num}}" id='btn-generate_{{i + num}}'>Modify<br>Scene
                          {{i + num}}</button>
                      {% endif %}
                    {% else %}
                      Incomplete
                    {% endif %}
                  </td>
                  <td class='{{cl}}'>
                    {% if script[i][0].type == 'movie' %}
                      <video width="80" height="45" controls="controls" autoplay="autoplay" muted="muted" class="img">
                        <source src="../data/{{title}}/images/{{script[i][0].image}}" type="video/mp4">
                      </video>
                    {% elseif script[i][0].type == 'still' %}
                      <img width="80" height="45" src="../data/{{title}}/images/{{script[i + num][0].image}}" class="img" alt="img_{{i}}"/>
                    {% else %}
                      <p style='font-size: 50%;'>No image</p>
                    {% endif %}
                  </td>
                  <td style='background:black;'>&nbsp;&nbsp;</td>
                {% endif %}
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src='../js/parent.js'></script>
<script src='../js/video.js'></script>
{%endblock%}