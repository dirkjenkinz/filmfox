<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8'/>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'/>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'/>
    <title>FilmFox</title>
    <link rel='stylesheet' href='../css/style.css'/>
    <link rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'/>
    <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
  </head>

  <body>
    <div class='container-fluid'>
      <div class='row top'>
        <div class='col-md-2'>
          <h4>Film Fox</h4>
        </div>
        <div class='col-md-1' hidden="hidden">
          <p id='ptr'>{{ptr}}</p>
        </div>
        <div class='col-md-3 data-right' id='title'>
          <h5>{{ title }}</h5>
        </div>
        <div class='col-md-1'></div>
        <div class='col-md-2'>
          <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-back'>Go Back</button>
        </div>
      </div>
      <div class='row show'>
        <div class='col-md-12'>
          <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
            <tbody>
              {% for i in range(0, package.length, 5) -%}
                <tr>
                  {% for num in range(0, 5) -%}
                    {% if  (package[i + num]) %}
                    <td class='data-left'>
                      Scene
                      {{i + num}}
                    </td>
                    <td class='data-left'>
                      {% if package[i + num][0][1] == 'movie' %}
                        <video width="80" height="45" controls="controls" autoplay="autoplay" muted="muted" id="img_{{i}}" class="img">
                          <source src="../data/{{title}}/images/{{package[i + num][0][0]}}" type="video/mp4">
                        </video>
                      {% else %}
                        <img width="80" height="45" src="../data/{{title}}/images/{{package[i + num][0][0]}}" id="img_{{i}}" class="img" alt="img_{{i}}"/>
                      {% endif %}
                    </td>
                    <td class='data-left'>
                      {% if gen[i + num ] == 'no' %}
                        <button class='btn btn-block btn-edit btn-sm btn-generate' value="{{i + num}}" id='btn-generate_{{i + num}}'>Generate</button>
                      {% else %}
                        <button class='btn btn-block btn-modify btn-sm btn-generate' value="{{i + num}}" id='btn-generate_{{i + num}}'>Modify</button>
                      {% endif %}
                    </td>
                    <td style='background:black;'>&nbsp;&nbsp;</td>
                    {% endif %}
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <script>
    $('.btn-generate').on('click', (e) => {
      const title = $('#title')[0].innerText;
      const ptr = $('#ptr')[0].innerText;
      scene = e.target.value;
      window.location.href = `/create-video?title=${title}&ptr=${ptr}&scene=${scene}`
    })
    $('#btn-back').on('click', () => {
      const title = $('#title')[0].innerText;
      const ptr = $('#ptr')[0].innerText;
      window.location.href = `/display?title=${title}&ptr=${ptr}`;
    })
  </script>
</body>
</html>