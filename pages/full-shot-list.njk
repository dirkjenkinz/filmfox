{% extends "parent.njk" %}
{% block page %}
  <div class='row top'>
    <p id='size' hidden="hidden">{{size}}</p>
    <div class='col-md-2'>
      <button class='btn btn-block btn-edit btn-sm' id='btn-hide-and-show' value='{{i}}'>Hide All</button>
    </div>
  </div>
  <div class='row top'>
    <div class='row tableFixHead' id='tabhead'>
      <div class='col-md-12'>
        <table id='table-shots'>
          <tbody>
            {% set num = 0 %}
            {% for i in range(1, shotList.length) -%}
              <tr id='row_{{i}}' style='font-size:80%;'>
                <td>
                  <button class='btn btn-block btn-edit btn-sm btn-scene' id='btn-scene-{{i}}' value='{{i}}'>
                    Scene
                    {{shotList[i].scene}}:
                    {{slugList[i]}}
                  </button>
                </td>
                <td>{{shotList[i].note}}</td>
              </tr>
              <tr>
                <td colspan='4'>
                  <table id='table-shots-list-{{i}}'>
                    <thead>
                      <tr>
                        <th class='data-central' style='width: 7%;'>Shot #</th>
                        <th class='data-central' style='width: 7%;'>Shot</th>
                        <th class='data-central' style='width: 14%;'>Angle</th>
                        <th class='data-central' style='width: 10%;'>Audio</th>
                        <th class='data-central' style='width: 22%;'>Subject</th>
                        <th class='data-central' style='width: 42%;'>Description</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for line in range(0, shotList[i].lines.length) %}
                        <tr style='font-size:70%;'>
                          <td>
                            {{num}}</td>
                          <td>
                            {{shotList[i].lines[line].shot}}
                          </td>
                          <td>
                            {{shotList[i].lines[line].angle}}
                          </td>
                          <td>
                            {{shotList[i].lines[line].audio}}
                          </td>
                          <td>
                            {{shotList[i].lines[line].subject}}
                          </td>
                          <td>
                            {{shotList[i].lines[line].description}}
                          </td>
                        </tr>
                        {% set num = num + 1 %}
                      {% endfor %}
                    </tbody>
                    <tr>
                      <td colspan='6' style='background: SteelBlue; font-size:20%;'>&nbsp;</td>
                    </tr>
                  </table>
                </td>
              </tr>
            {%- endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script src='../js/parent.js'></script>
  <script src='../js/full-shot-list.js'></script>
  <script>
    $(() => {
      $("#nav-display-full").addClass('active');
    });
  </script>
{% endblock %}