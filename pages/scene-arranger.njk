{% extends "parent.njk" %}
{% block page %}
  <p id='size' hidden="hidden">{{size}}</p>
  <div class='row top'>
    <div class='row tableFixHead' id='tabhead'>
      <div class='col-md-12'>
        <table id='table-shots'>
          <tbody>
            {% set num = 0 %}
            {% for i in range(1, shotList.length) -%}
              <tr id='row_{{i}}' class='display-box' style='font-size:75%;'>
                <td class='data-left' style='width: 12%; font-weight: bold;'>Scene
                  {{shotList[i].scene}}</td>
                <td class='data-left' colspan='2' style='width: 33%;'>{{slugList[i]}}</td>
                <td class='data-left' style='width: 33%;'>{{shotList[i].note}}</td>
                <td style='width: 8%;'>
                  {% if i == 1 %}
                    <button class='btn btn-block btn-edit btn-sm btn-up' id='btn-up-{{i}}' disabled="disabled">Up
                    </button>
                  {% else %}
                    <button class='btn btn-block btn-edit btn-sm btn-up' id='btn-up-{{i}}' value='{{i}}'>Up
                    </button>
                  {% endif %}
                </td>
                <td style='width: 8%;'>
                  {% if i == size - 1 %}
                    <button class='btn btn-block btn-edit btn-sm btn-down' id='btn-down-{{i}}' disabled="disabled">Down
                    </button>
                  {% else %}
                    <button class='btn btn-block btn-edit btn-sm btn-down' id='btn-down-{{i}}' value='{{i}}'>Down
                    </button>
                  {% endif %}
                </td>
              </tr>
              {%- endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <script src='../js/parent.js'></script>
    <script src='../js/scene-arranger.js'></script>
    <script>
      $(() => {
        $("#nav-arranger").addClass('active');
      })
    </script>
  {% endblock %}