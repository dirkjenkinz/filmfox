{% extends "parent.njk" %}
{% block page %}
  <p id='size' hidden="hidden">{{size}}</p>
  <p id='top' hidden="hidden">{{top}}</p>
  <div class='row top'>
    <div class='row tableFixHead3'>
      <div class='col-md-8'>
        <table>
          <tbody style='font-size: 80%;'>
            {% set num = 0 %}
            {% for i in range(top, finish) -%}
              <tr id='row_{{i}}' class='display-box' style='font-size:80%;'>
                <td class='data-left' style='width: 6%; font-weight: bold;'>Scene
                  {{shotList[i].scene}}</td>
                <td class='data-left' colspan='2' style='width: 33%;'>{{slugList[i]}}</td>
                <td class='data-left' style='width: 33%;'>{{shotList[i].note}}</td>
                <td style='width: 4%;'>
                  {% if i == 1 %}
                    <button class='btn btn-block btn-edit btn-sm btn-up' style='font-size: 80%;' id='btn-up-{{i}}' disabled="disabled">Up
                    </button>
                  {% else %}
                    <button class='btn btn-block btn-edit btn-sm btn-up' style='font-size: 80%;' id='btn-up-{{i}}' value='{{i}}'>Up
                    </button>
                  {% endif %}
                </td>
                <td style='width: 4%;'>
                  {% if i == size - 1 %}
                    <button class='btn btn-block btn-edit btn-sm btn-down'  style='font-size: 80%;'  id='btn-down-{{i}}' disabled="disabled">Down
                    </button>
                  {% else %}
                    <button class='btn btn-block btn-edit btn-sm btn-down'  style='font-size: 80%;'  id='btn-down-{{i}}' value='{{i}}'>Down
                    </button>
                  {% endif %}
                </td>
              </tr>
            {%- endfor %}
          </tbody>
        </table>
      </div>
      <div class='col-md-1' class='slidecontainer'>
          <input type="range" orient='vertical' min="1" max="{{size - 1 }}" value="{{top}}" id='slider-scene'>
          <p id='output'>{{top}}
      </div>
    </div>
    <script src='../js/parent.js'></script>
    <script src='../js/scene-arranger.js'></script>
    <script>
      $(() => {
        $("#nav-arranger").addClass('active');
      })
    </script>
  {% endblock %}