{% extends "parent.njk" %}
{% block page %}
  <div class='row'>
    <div class='col-md-4'>
      <br>
      <audio id='master-play' controls="controls">
        <source src='' type="audio/mpeg">
      </audio>
    </div>
    <div class='col-md-2'>
      <h3>{{msg}}</h3>
    </div>
    <div class='col-md-4'>&nbsp;</div>
    <div class='col-md-2'>
      <button type='button' class='btn btn-block btn-sm btn-return'>Back to Characters</div>
    </div>
    <div class='row tableFixHead' id='tabhead'>
      <div class='col-md-12'>
        <table class='table-bordered table-sm table-dark table-grid' id='tab-char'>
          <tbody>
            <tr>
              <td class='data-char' colspan='3'>
                <h3 id='character'>{{character}}</h3>
              </td>
              <td class='data-char'></td>
              <td class='data-char'></td>
              <td class='data-char' id='current-voice' colspan='2'>
                {{currentVoice}}
              </td>
            </tr>
            {% for i in range(0, elements.length) -%}
              <tr>
                <td class='data-char' colspan='3'>Scene:
                  {{elements[i].sceneNumber}}
                  <br>Element:
                  {{elements[i].elementNumber}}
                </td>
                <td class='data-char'>
                  {{elements[i].voice}}
                </td>
                <td class='data-char'>
                  {{elements[i].dialogue}}
                </td>
                <td class='data-right'>
                  {% if elements[i].sound %}
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-play' value='{{elements[i].sound}}'>
                      Play
                    </button>
                  {% else %}
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-play' disabled="disabled" value='{{elements[i].sound}}'>
                      Play
                    </button>
                  {% endif %}

                </td>
                <td class='data-right'>
                  <button type='button' class='btn btn-edit btn-block btn-sm btn-gen' value='{{elements[i].sceneNumber}}_{{elements[i].elementNumber}}'>
                    Generate
                  </button>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script src='../js/parent.js'></script>
  <script src='../js/edit-character.js'></script>
{% endblock %}