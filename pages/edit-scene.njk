{% extends "parent-no-buttons.njk" %}
{% block page %}
  <div class='row top '>
    <div class='col-md-2'>
      <button class='btn btn-block btn-edit btn-sm' id='btn-back-to-scenes'>
        Back to Scenes
      </button>
      <p id='scene' hidden='hidden'>{{scene}}</p>
    </div>
  </div>

  <div class='row'>
    <div class='col-md-12'>
      <table class='table-bordered table-sm table-dark table-grid' id='tab_header'>
        <tbody>
          <tr>
            <td class='data-left' colspan='2'>
              <h5>Scene
                {{scene}}
              </h5>
            </td>
            <td style='width: 80%;'>
              <label for="note">Note:</label>
              <input type="text" id="note" name="note" size='100' value='{{note}}'>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
  <div class='row tableFixHead' id='tabhead'>
    <table class='table-bordered table-sm table-dark table-grid' id='tab_main'>
      <tbody>
        {% for i in range(0, elements.length) -%}
          <tr>
            <td class='data-left'>
              {{elements[i].number}}
            </td>
            <td class='data-left'>
              {{elements[i].speaker}}
            </td>
            <td class='data-left' style='width: 80%;'>
              {{elements[i].dialogue}}
            </td>
            <td class='data-left'>
              {% if elements[i].type === 'movie' %}
                <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i}}" class="img" muted="muted">
                  <source src="../data/{{title}}/images/{{elements[i].image}}" type="video/mp4">
                </video>
              {% else %}
                <img width="160" height="90" src="../data/{{title}}/images/{{elements[i].image}}" id="img_{{i}}" class="img" alt="elements[i][0]"/>
              {% endif %}
              <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-change' value="{{elements[i].number}}">
                Change Image
              </button>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
<script src='../js/edit-scene.js'></script>
{% endblock %}