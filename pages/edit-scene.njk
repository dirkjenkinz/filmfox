{% extends "parent.njk" %}
{% block page %}
  <div class='row tableFixHead' id='tabhead'>
        <div class='col-md-12'>
          <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
            <tbody>
              <tr>
              <td  class='data-left'>&nbsp;</td>
              <td  class='data-left' colspan='3'><h4>Scene {{scene}}</h4></td></tr> 
              {% for i in range(0, elements.length) -%}
                <tr>
                  <td class='data-left'>
                    {{elements[i].number}}
                  </td>
                  <td class='data-left'>
                    {{elements[i].speaker}}
                  </td>
                  <td class='data-left'>
                    {{elements[i].dialogue}}
                  </td>
                  <td class='data-left'>
                    {% if elements[i].type === 'movie' %}
                      <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i}}" class="img" muted="muted">
                        <source src="../data/{{title}}/images/{{elements[i].image}}" type="video/mp4">
                      </video>
                    {% else %}
                      <img width="160" height="90" src="../data/{{title}}/images/{{elements[i].image}}" id="img_{{i}}" class="img" alt="elements[i][0]"/>
                    {% endif %}
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-change' value="{{elements[i].number}}">
                      Change Image
                    </button>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      <script src='../js/header.js'></script>
      <script src='../js/edit-scene.js'></script>
{% endblock %}