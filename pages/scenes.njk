{% extends "parent.njk" %}
{% block page %}
  <div class='row tableFixHead' id='tabhead'>
    <div class='col-md-12'>
      <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
        <tbody>
          {% for i in range(0, sceneList.length, 3) -%}
            <tr>
              {% for num in range(0, 3) -%}
                {% if sceneList[i + num] %}
                  <td class='data-left' style='font-size:80%;' width='20%'>
                    {{sceneList[i+num].slug}}
                    <br>
                    {% if sceneList[i + num].type === 'movie' %}
                      <video width="160" height="90" controls="controls" autoplay="autoplay" class="img" muted="muted">
                        <source src="../data/{{title}}/images/{{sceneList[i + num].image}}" type="video/mp4">
                      </video>
                    {% elseif sceneList[i + num].type === 'still' %}
                      <img width="160" height="90" src="../data/{{title}}/images/{{sceneList[i + num].image}}" class="img" alt="sceneList[i + num][0]"/>
                    {% else %}
                      <p style='font-size: 70%'>No image</p>
                    {% endif %}
                  </td>
                  <td class='data-left' width='12%'>
                    Scene
                    {{i + num}}
                    <br>
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-scene-shot-list' value="{{i + num}}">
                      Shot List
                    </button>
                  </td>
                  <td class='sep'>&nbsp;</td>
                {% endif %}
              {% endfor %}
            </tr>

            <tr>
              {% for num in range(0, 3) -%}
                {% if sceneList[i + num] %}
                  <td colspan='2'>
                    <div class='col-md-8'>
                      <textarea id="note-{{i + num}}" class='note' name="note-{{i + num}}" rows="2" cols="44">{{sceneList[i + num].note}}</textarea>
                    </div>
                  </td>
                  <td class='sep'></td>
                {% endif %}
              {% endfor %}
            </tr>

            <tr>
              {% for num in range(0, 3) -%}
                <td colspan='3' class='sep'>
                  &nbsp;
                </td>
              {% endfor %}
            </tr>

          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  <script src='../js/parent.js'></script>
  <script src='../js/scenes.js'></script>
</body>
{% endblock %}