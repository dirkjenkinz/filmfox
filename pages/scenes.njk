<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8'/>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'/>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'/>
    <title>FilmFox</title>
    <link rel='stylesheet' href='../css/style.css'/>
    <link rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'/>
    <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
  </head>

  <body>
    <div class='container-fluid'>
      <div class='row top'>
        <div class='col-md-2'>
          <h4>Film Fox</h4>
        </div>
        <div class='col-md-1' hidden="hidden">
          <p id='ptr'>{{ptr}}</p>
          <p id='element'>{{element}}</p>
        </div>
        <div class='col-md-3 data-right' id='title'>
          <h5>{{ title }}</h5>
        </div>
        <div class='col-md-1'></div>
        <div class='col-md-4'>
          <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-back'>Go Back</button>
        </div>
      </div>
      <div class='row show'>
        <div class='col-md-12'>
          <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
            <tbody>
              {% for i in range(0, sceneList.length, 3) -%}
                <tr>
                  {% for num in range(0, 3) -%}
                    <td class='data-right'>
                      {{i + num}}
                      <br>
                      {{sceneList[i + num].element}}
                    </td>
                    <td class='data-left' colspan='2'>
                      {{sceneList[i+num].slug}}
                      <br>
                      {% if sceneList[i + num].type === 'movie' %}
                        <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i + num}}" class="img" muted="muted">
                          <source src="../data/{{title}}/images/{{sceneList[i + num].image}}" type="video/mp4">
                        </video>
                      {% else %}
                        <img width="160" height="90" src="../data/{{title}}/images/{{sceneList[i + num].image}}" id="img_{{i + num}}" class="img" alt="sceneList[i + num][0]"/>
                      {% endif %}
                    </td>
                  {% endfor %}
                </tr>
                <tr>
                  {% for num in range(0, 3) -%}
                    <td class='data-right'>&nbsp;</td>
                    <td>
                      <button type='button' class='btn btn-edit btn-block btn-sm btn-change' value="{{sceneList[i + num].element}}">
                        Change Image
                      </button>
                    </td>
                    <td>
                      <button type='button' class='btn btn-edit btn-block btn-sm btn-edit-scene' value="{{i + num}}">
                        Edit Scene
                      </button>
                    </td>
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      <script src='../js/scenes.js'></script>
    </body>
  </html>