<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8'/>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'/>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'/>
    <title>FilmFox</title>
    <link rel='stylesheet' href='../css/style.css'/>
    <link rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'/>
    <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
  </head>
  <body>
    <div class='container-fluid'>
      <div class='row'>
        <div class='col-md-2'>
          <h4>Film Fox</h4>
        </div>
        <div class='col-md-1' hidden="hidden">
          <p id='ptr'>{{ptr}}</p>
          <p id='endpoint'>
          {{end}}
        </p>
      </div>
      <div class='col-md-3 data-right' id='title'>
        <h5>{{ title }}</h5>
      </div>
      <div class='col-md-1'>
        <p id='length' hidden="hidden">{{scenes.length}}</p>
      </div>
    </div>
    <div class='row'>
      <div class='col-md-12 well' style='background: silver;'>
        <table class='table-bordered table-sm table-dark table-grid table-scroll' id='scenes-table'>
          <tbody>
            <tr id='row_{{i}}'>
              {% for i in range(0, scenes.length) -%}
                <td class='data-display' style='width: 180px;'>
                  Scene
                  {{scenes[i][2]}}<br>Element
                  {{elements[i]}}</td>
              </td>
            {%- endfor %}
          </tr>
          <tr>
            {% for i in range(0, scenes.length) -%}
              <td class='data-display' style='width: 180px; font-size: 70%;'>
                {{scenes[i][1]}}
              </td>
            {%- endfor %}
          </tr>
          <tr>
            {% for i in range(0, scenes.length) -%}
              <td class='data-display' style='width: 180px; font-size: 70%;'>
                <button type='button' class='btn btn-edit btn-block btn-sm btn-play' value={{scenes[i][4]}}>
                Play
                </button>
                </td>
              {%- endfor %}
            </tr>
            <tr>
              {% for i in range(0, scenes.length) -%}
                <td class='data-display' style='width: 180px; font-size: 70%;'>
                  {{scenes[i][5]}}
                </td>
              {%- endfor %}
            </tr>
            <tr>
              {% for i in range(0, scenes.length) -%}
                <td class='data-display card' style='width: 180px;' id="crd_{{i}}">
                  {% if images[i][1] === 'movie' %}
                    <video width="160" height="90" controls="controls" autoplay="autoplay" id="img_{{i}}" class="img" muted="muted">
                      <source src="../data/{{title}}/images/{{images[i][0]}}" type="video/mp4">
                    </video>
                  {% else %}
                    <img width="160" height="90" src="../data/{{title}}/images/{{images[i][0]}}" id="img_{{i}}" class="img" alt="{{images[i][0]}}"/>
                  {% endif %}
                </td>
              {%- endfor %}
            </tr>
            <tr>
              {% for i in range(0, scenes.length) -%}
                <td class='data-right' style='width: 180px;'>
                  <button type='button' class='btn btn-edit btn-block btn-sm btn-change' value={{elements[i]}}>
                    Change
                  </button>
                </td>
              {%endfor %}
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script>
    $('.btn-play').on('click', (e) => {
      const title = $('#title')[0].innerText;
      const ptr = $('#ptr')[0].innerText;
      element = e.target.value;
      window.location.href = `/play?title=${title}&element=${element}&ptr=${ptr}`
    }),
    $('.btn-change').on('click', (e) => {
      const f = $('#title')[0].innerText;
      const ptr = $('#ptr')[0].innerText;
      const i = e.target.value;
      var p = $('#scenes-table').first();
      window.location.href = `/gallery?title=${f}&ptr=${ptr}&img=${i}&caller=scenes`
    }),
    $('.btn-play').on('click', (e) => {
      const title = $('#title')[0].innerText;
      const ptr = $('#ptr')[0].innerText;
      element = e.target.value;
      window.location.href = `/play?title=${title}&element=${element}&ptr=${ptr}`
    })
  </script>
</body>
</html>