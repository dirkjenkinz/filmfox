{% block header %}
  <!DOCTYPE html>
  <html lang='en'>
    <head>
      <meta charset='UTF-8'/>
      <meta http-equiv='X-UA-Compatible' content='IE=edge'/>
      <meta name='viewport' content='width=device-width, initial-scale=1.0'/>
      <title>FilmFox</title>
      <!-- Link to custom stylesheets -->
      <link rel='stylesheet' href='../css/style.css'/>
      <link rel='stylesheet' href='../css/parent.css'/>
      <link rel='stylesheet' href='../css/breakdown.css'/>
      <!-- Link to Bootstrap stylesheet -->
      <link rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'/>
      <!-- Include jQuery library -->
      <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
      <!-- Include Bootstrap JavaScript -->
      <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
    </head>
    <body>
      <div class='container-fluid'>
        <div class='row top' style='font-size: 70%;'>
          <div class='col-md-2'>
            <!-- Display 'Film Fox' -->
            Film Fox
          </div>
          <div class='col-md-1'></div>
          <div class='col-md-6' id='filmTitle'>
            <!-- Display dynamic title -->
            {{ title }}
            <!-- Hidden input fields for various data -->
            <p id='length' hidden='hidden'>{{script.length}}</p>
            <p id='sceneNumber' hidden='hidden'>{{sceneNumber}}</p>
            <p id='elementNumber' hidden='hidden'>{{elementNumber}}</p>
            <p id='highestScene' hidden='hidden'>{{highestScene}}</p>
            <p id='audio' hidden="hidden">{{audio}}</p>
            <p id='voice' hidden="hidden">{{voice}}</p>
            <p id='mute' hidden="hidden">{{mute}}</p>
            <p id='speak' hidden="hidden">{{speak}}</p>
            <p id='para' hidden="hidden">{{para}}</p>
            <p id='start' hidden="hidden">{{start}}</p>
            <p id='finish' hidden="hidden">{{finish}}</p>
            <p id='element' hidden="hidden">{{element}}</p>
            <p id='scr1' hidden="hidden">{{scr1}}</p>
            <p id='caller' hidden="hidden">{{caller}}</p>
          </div>
          <div class='col-md-3' style='text-align: right;'>
            <!-- Display dynamic page title -->
            {{page}}
          </div>
        </div>
        <div class='row top topnav' style='padding-bottom: 0; margin-bottom:0;'>
          <div class='col-md-9'>
            <!-- Navigation links -->
            <p id='nav-showreel'>SHOWREEL</p>
            <p id='nav-arranger'>Scene Arranger</p>
            <p id='nav-scene-shot-list'>Scene Shot List</p>
            <p id='nav-display-full'>Full Shot List</p>
            <p id='nav-sheets'>Sheets</p>
            <p id='nav-credits'>Credits</p>
            <p id='nav-breakdown'>Scene Breakdown</p>
            <p id='nav-report'>Breakdown Reports</p>
            <p id='nav-categories'>Categories</p>
          </div>
          <div class='col-md-2'>
            <!-- 'Generate Paperwork' button -->
            <button class='btn btn-block btn-edit btn-sm' id='btn-generate'>Generate Paperwork</button>
          </div>
          <div class='col-md-1'>
            <!-- 'FRONT' text -->
            <p id='nav-front'>FRONT</p>
          </div>
        </div>
      {% endblock %}
      {% block page %}{% endblock %}
      {% block footer %}
      </body>
    </html>
  {% endblock %}
