{% extends "parent.njk" %}
{% block page %}
  <div class='row'>
    <div class='col-md-12'>
      <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
        <thead>
          <tr>
            <th class='shot-header' style='width: 10%;'>Scene
              {{scene}}</th>
            <th class='shot-header'>
              {{slug}}
            </th>
          </tr>
          <tr>
            <td class='data-left' colspan='2'>
              <label for="input-note">Note:</label>
              <input type="text" id="input-note" name="input-note" size='100' value='{{note}}'>
            </td>
            <td>
              {% if scene > 0 %}
              <button class='btn btn-block btn-edit btn-sm btn-previous' id='btn-previous'>
                Previous
              </button>
              {% else %}
              <button class='btn btn-block btn-edit btn-sm btn-previous' id='btn-previous' disabled>
                Previous
              </button>
              {% endif %}
            </td>
            <td>
              {% if scene < size - 1 %}
              <button class='btn btn-block btn-edit btn-sm btn-next' id='btn-next'>
                Next
              </button>
              {% else %}
              <button class='btn btn-block btn-edit btn-sm btn-next' id='btn-next' disabled>
                Next
              </button>
              {% endif %}
            </td>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class='data-left'>
              {{slug.dialogue}}
            </td>
            <td class='data-left'>
              {{slug.note}}
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class='row'>
    <div class='col-md-12'>&nbsp;</div>
  </div>

  <div class='row tableFixHead' id='tabhead'>
    <div class='col-md-12'>
      <table class='table-bordered table-sm table-dark table-grid' id='tab-shot'>
        <thead>
          <tr>
            <th class='shot-header'>
              #
            </th>
            <th class='shot-header'>
              Shot
            </th>
            <th class='shot-header'>
              Camera Angle
            </th>
            <th class='shot-header'>
              Camera Move
            </th>
            <th class='shot-header'>
              Audio
            </th>
            <th class='shot-header'>
              Subject
            </th>
            <th class='shot-header'>
              Description
            </th>
          </tr>
        </thead>
        <tbody>
          {% for i in range(0, lines.length) -%}
            <tr>
              <td class='data-left'>
                {{i +1}}
              </td>
              <td class='data-left'>
                <select id='shot-shot_{{i}}' class='shot-select shot-shot'>
                  {% for index in range(0, shots.length) -%}
                    {% if shots[index] == lines[i].shot %}
                      <option value='{{shots[index]}}' selected="selected">
                        {{shots[index]}}
                      </option>
                    {% else %}
                      <option value='{{shots[index]}}'>
                        {{shots[index]}}
                      </option>
                    {% endif %}
                  {% endfor %}
                </select>
              </td>
              <td class='data-left'>
                <select id='shot-angle_{{i}}' class='shot-select shot-angle'>
                  {% for index in range(0, angles.length) -%}
                    {% if angles[index] === lines[i].angle %}
                      <option value='{{angles[index]}}' selected="selected">
                        {{angles[index]}}
                      </option>
                    {% else %}
                      <option value='{{angles[index]}}'>
                        {{angles[index]}}
                      </option>
                    {% endif %}
                  {% endfor %}
                </select>
              </td>
              <td class='data-left'>
                <select name="move_{{i}}" id='shot-move_{{i}}' class='shot-select'>
                  {% for index in range(0, moves.length) -%}
                    {% if moves[index] == lines[i].move %}
                      <option value='{{moves[index]}}' selected="selected">
                        {{moves[index]}}
                      </option>
                    {% else %}
                      <option value='{{moves[index]}}'>
                        {{moves[index]}}
                      </option>
                    {% endif %}
                  {% endfor %}
                </select>
              </td>
              <td class='data-left'>
                <select name="audio{{i}}" id='shot-audio_{{i}}' class='shot-select'>
                  {% for index in range(0, audio.length) -%}
                    {% if audio[index] == lines[i].audio %}
                      <option value='{{audio[index]}}' selected="selected">
                        {{audio[index]}}
                      </option>
                    {% else %}
                      <option value='{{audio[index]}}'>
                        {{audio[index]}}
                      </option>
                    {% endif %}
                  {% endfor %}
                </select>
              </td>
              <td class='data-left'>
                <textarea id='shot-subject_{{i}}' class='shot-subject' rows='2' cols='30'>{{lines[i].subject | trim}}</textarea>
              </td>
              <td class='data-left'>
                <textarea id='shot-description_{{i}}' class='shot-description' rows="2" cols='30'>{{lines[i].description | trim}}</textarea>
              </td>
              <td>
                <button class='btn btn-block btn-edit btn-sm btn-add' value='{{i}}'>
                  +
                </button>
              </td>
              <td>
              {% if lines.length > 1 %} 
                <button class='btn btn-block btn-edit btn-sm btn-delete' value='{{i}}'>
                  -
                </button>
                {% else %}
                <button class='btn btn-block btn-edit btn-sm btn-delete' value='{{i}}' disabled>
                  -
                </button>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <script src='../js/parent.js'></script>
  <script src='../js/scene-shot-list.js'></script>
{% endblock %}