<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8'/>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'/>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'/>
    <title>FilmFox</title>
    <link rel='stylesheet' href='../css/style.css'/>
    <link rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'/>
    <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
  </head>

  <body>
    <div class='container-fluid'>
      <div class='row top'>
        <div class='col-md-2'>
          <h4>Film Fox</h4>
        </div>
        <div class='col-md-3' id='title'>{{title}}</div>
        <div class='col-md-5'>
          {{slug[current]}}
        </div>
        <div class='col-md-2'>
          <button type='button' class='btn btn-edit btn-block btn-sm' id='btn-back'>Go Back</button>
        </div>
      </div>
      <div class="row" style='background: silver; color: black;'>
        <div class='col-md-1'>
          <p id='current'>{{current}}</p>
          <p id='start'>{{showreel[current].start}}</p>
          <p id='finish'>{{showreel[current].finish}}</p>
          <p id='ptr' hidden="hidden">{{ptr}}</p>
          <br><br><br><br>
          <br><br><br><br>
          {% if muted == 'no' %}
            <button class='btn btn-block btn-edit btn-sm' id='btn-mute'>
              MUTE
            </button>
          {% else %}
            <button class='btn btn-block btn-edit btn-sm' id='btn-mute'>
              UNMUTE
            </button>
          {% endif %}
        </div>
        <div class='col-md-8'>
          {% if imageType[current] === 'movie' %}
            <video width="800" height="450" controls="controls" autoplay="autoplay" id="img_{{i}}" class="img" muted="muted">
              <source src="../data/{{title}}/images/{{showreel[current].card}}" type="video/mp4">
            </video>
          {% else %}
            <img id='piccy' width="800" height="450" src="../data/{{title}}/images/{{showreel[current].card}}" alt="card"/>
          {% endif %}
        </div>
        <div class='col-md-3'>
          <br>
          <p style='text-align : center;'>
            {{showreel[current].character}}
          </p>
          <p>{{showreel[current].dialogue}}</p>
        </div>
      </div>
      <div class='row'>&nbsp;</div>
      <div class='row'>
        <div class='col-md-1'></div>
        <div class='col-md-2'>
          <button class='btn btn-block btn-edit btn-sm' id='btn-previous'>
            PREVIOUS
          </button>
        </div>
        <div class='col-md-4'></div>
        <div class='col-md-2'>
          <button class='btn btn-block btn-edit btn-sm' id='btn-next'>
            NEXT
          </button>
        </div>
        <div class='col-md-3'></div>
      </div>
      <div class='row'>&nbsp;</div>
    </div>
    <script>
      $('#btn-back').on('click', () => {
        const title = $('#title')[0].innerText;
        const ptr = $('#ptr')[0].innerText;
        window.location.href = `/display?title=${title}&ptr=${ptr}`;
      }),
      $("#display").on("click", () => {
        const fff = $("#title")[0].outerText;
        const ptr = $("#ptr")[0].innerText;
        window.location.href = `/display?title=${title}.fff&ptr=${ptr}`
      }),
      $("#btn-next").on("click", () => {
        const title = $("#title")[0].innerText;
        const ptr = $("#ptr")[0].innerText;
        let current = $("#current")[0].innerText;
        current++;

        if ($('#btn-mute')[0].innerText === 'MUTE') {
          muted = 'no';
        } else {
          muted = 'yes';
        };

        window.location.href = `/play-showreel?title=${title}&ptr=${ptr}&current=${current}&muted=${muted}`
      }),
      $("#btn-previous").on("click", () => {
        const title = $("#title")[0].innerText;
        const ptr = $("#ptr")[0].innerText;
        let current = $("#current")[0].innerText;
        current--;

        if (current < 0) {
          current = 0;
        }

        if ($('#btn-mute')[0].innerText === 'MUTE') {
          muted = 'no';
        } else {
          muted = 'yes';
        };

        window.location.href = `/play-showreel?title=${title}&ptr=${ptr}&current=${current}&muted=${muted}`
      }),
      $("#btn-mute").on("click", () => {
        const title = $("#title")[0].innerText;
        const ptr = $("#ptr")[0].innerText;
        const current = $("#current")[0].innerText;
        let mute;

        if ($('#btn-mute')[0].innerText === 'MUTE') {
          muted = 'yes';
        } else {
          muted = 'no';
        };

        window.location.href = `/play-showreel?title=${title}&ptr=${ptr}&current=${current}&muted=${muted}`;
      })
    </script>
  </body>
</html>