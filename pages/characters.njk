{% extends "parent.njk" %}
{% block page %}
  <div class='row tableFixHead' id='tabhead'>
    <div class='col-md-9'>
      <table class='table-bordered table-sm table-dark table-grid' id='tab-chars' style='font-size: 75%;'>
        <tbody>
          {% for i in range(0, characters.length, 3) -%}
            <tr>
              {% for num in range(0, 3) -%}
                {% if characters[i + num] %}
                  <td class='data-right'>
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-edit-character' value='{{characters[i + num][0]}}'>
                      {{characters[i + num][0]}}
                    </button>
                  </td>
                  <td class='data-left'>
                    {{characters[i + num][1]}}
                  </td>
                  {% if num !== 2 %}
                    <td>&nbsp;&nbsp;&nbsp;</td>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class='col-md-3'>
      <div class='row'>
        <p style='text-align:center;'>Non-Speaking Characters</p>
      </div>
      <div class='row' style='text-align: center;'>
        <br>
        <input type="text" id="input-add-character" name="input-add-character" size='30'>
      </div>
      <div class='row'>
        <button type='button' class='btn btn-edit btn-block btn-sm btn-add-character'>Add Non-Speaking Character</button>
      </div>
      <div class='row'>
        <br>
        <table class='table-bordered table-sm table-dark table-grid' id='tab_non' style='font-size: 75%;'>
          {% for i in range(0, nonSpeakers.length, 2) -%}
            <tr>
              {% for num in range(0, 2) -%}
                <td class='data-left'>
                  {{nonSpeakers[i + num ]}}
                </td>
              {% endfor %}
            </tr>
          {% endfor %}
        </table>
      </div>
    </div>
  </div>
  <script src='../js/parent.js'></script>
  <script src='../js/characters.js'></script>
{% endblock %}