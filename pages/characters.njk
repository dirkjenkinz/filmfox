{% extends "parent.njk" %}
{% block page %}
  <div class='row tableFixHead' id='tabhead'>
    <div class='col-md-12'>
      <table class='table-bordered table-sm table-dark table-grid' id='tab_img'>
        <tbody>
          {% for i in range(0, characters.length, 3) -%}
            <tr>
              {% for num in range(0, 3) -%}
                {% if characters[i + num] %}
                  <td class='data-right'>
                    <button type='button' class='btn btn-edit btn-block btn-sm btn-edit-character' value='{{characters[i + num][0]}}'>
                      {{characters[i + num][0]}}
                    </button>
                  </td>
                  <td class='data-right'>
                    {{characters[i + num][1]}}
                  </td>
                  <td>&nbsp;&nbsp;</td>
                {% endif %}
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  <script src='../js/parent.js'></script>
  <script src='../js/characters.js'></script>
{% endblock %}