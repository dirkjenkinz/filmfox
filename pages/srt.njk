<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta http-equiv='X-UA-Compatible' content='IE=edge' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>FilmFox</title>
    <link rel='stylesheet' href='../css/style.css' />
    <link
      rel='stylesheet'
      href='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css'
    />
    <script src='https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js'></script>
  </head>

  <body>
    <div class='container-fluid'>
      <div class="row top">
        <div class="col-md-2">
          <h4>Film Fox</h4>
        </div>
        <div class="col-md-1" hidden>
          <p id="ptr">{{ptr}}</p>
          <p id="endpoint">{{end}}</p>
        </div>
        <div class="col-md-4 data-right" id="title"><h5>{{ title }}</h5></div>
        <div class='col-md-1'></div>
        <div class='col-md-4'>
          <button type='button' class='btn btn-edit btn-block btn-sm' onclick="history.back()">Go Back</button>
        </div>
      </div>
      <div class='row show'>
       {% for i in range(0, srt.length) -%}
       <p class='para-srt'>{{srt[i]}}</p>
        {% if i % 4 == 2 %}
          <p>&nbsp;</p>
        {% endif %}
       {%- endfor %}
    </div>
    <script src='../js/srt.js'>
    </script>
  </body>
</html>
