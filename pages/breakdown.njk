{% extends "parent.njk" %}
{% block page %}
  <div class='row top'>
    <div class='col-md-2'>
      {% if sceneNumber > 0 %}
        <button type='button' class='btn-prevnext btn-sm' id='btn-first-scene'>
          First Scene
        </button>
      {% else %}
        <button type='button' class='btn-prevnext btn-sm' id='btn-first-scene' disabled="disabled">
          First Scene
        </button>
      {% endif %}
    </div>
    <div class='col-md-1'>&nbsp;</div>
    <div class='col-md-3'>
      {% if sceneNumber > 0 %}
        <button type='button' class='btn-prevnext btn-sm' id='btn-previous-scene'>
          Previous Scene
        </button>
      {% else %}
        <button type='button' class='btn-prevnext btn-sm' id='btn-previous-scene' disabled="disabled">
          Previous Scene
        </button>
      {% endif %}
    </div>
    <div class='col-md-3'>
      {% if sceneNumber < highestScene %}
        <button type='button' class='btn-prevnext btn-sm' id='btn-next-scene'>
          Next Scene
        </button>
      {%else %}
        <button type='button' class='btn-prevnext btn-sm' id='btn-next-scene' disabled="disabled">
          Next Scene
        </button>
      {% endif %}
    </div>
    <div class='col-md-1'>&nbsp;</div>
    <div class='col-md-2'>
      {% if sceneNumber < highestScene %}
        <button type='button' class='btn-prevnext btn-sm' id='btn-last-scene'>
          Last Scene
        </button>
      {% else %}
        <button type='button' class='btn-prevnext btn-sm' id='btn-last-scene' disabled="disabled">
          Last Scene
        </button>
      {% endif %}
    </div>
  </div>
  <!-- end of row 1 -->
  <div class='row top'>
    <p id='breakdown' hidden="hidden">{{breakdown}}</p>
    <div class='col-md-2' style='background: white; color:black; text-align: center;'>
      <b>ELEMENTS</b>
      <button type='button' class='btn-element' id='btn-cast' value='cast'>CAST MEMBERS</button>
      <button type='button' class='btn-element' id='btn-extras' value='extras'>EXTRAS</button>
      <button type='button' class='btn-element' id='btn-props' value='props'>PROPS</button>
      <button type='button' class='btn-element' id='btn-dressing' value='dressing'>SET DRESSING</button>
      <button type='button' class='btn-element' id='btn-costumes' value='costumes'>COSTUMES</button>
      <button type='button' class='btn-element' id='btn-makeup' value='makeup'>MAKEUP</button>
      <button type='button' class='btn-element' id='btn-vehicles' value='vehicles'>VEHICLES</button>
      <button type='button' class='btn-element' id='btn-stunts' value='stunts'>STUNTS</button>
      <button type='button' class='btn-element' id='btn-sfx' value='sfx'>SPECIAL EFFECTS</button>
      <button type='button' class='btn-element' id='btn-livestock' value='livestock'>LIVESTOCK</button>
      <button type='button' class='btn-element' id='btn-handler' value='handler'>ANIMAL HANDLER</button>
      <button type='button' class='btn-element' id='btn-music' value='music'>MUSIC</button>
      <button type='button' class='btn-element' id='btn-sounds' value='sounds'>SOUNDS</button>
      <button type='button' class='btn-remove-tag' id='btn-remove-tag'>Remove Tag</button>
      <br><br>
    </div>
    <div class='col-md-8   tableFixHead3' style='font-size: 75%;' id='scriptArea'>
      <p id='scene'>Scene
        {{sceneNumber}}</p>
      <p id='box'></p>
    </div>
    <div class='col-md-2' style='font-size:75%'>
      <br>
      <button type='button' class='btn-prevnext' id='btn-start-again'>Start Again</button>
      <br>
      <p class='cast'>
        Cast:
        {% for i in range(0, list.cast.length) -%}
          {{list.cast[i]}}
        {% endfor %}
      </p>
      <p class='extras'>
        Extras:
        {% for i in range(0, list.extras.length) -%}
          {{list.extras[i]}}
        {% endfor %}
      </p>
      <p class='props'>
        Props:
        {% for i in range(0, list.props.length) -%}
          {{list.props[i]}}
        {% endfor %}
      </p>
    </div>
  </div>
</div>
<script src='../js/parent.js'></script>
<script src='../js/breakdown.js'></script>
{% endblock %}