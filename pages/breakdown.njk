{% extends "parent.njk" %}
{% block page %}
  <div class='row top'>
    <div class='col-md-2' style='background: white; color:black; text-align: center;'>
      <b>ELEMENTS</b>
      <button type='button' class='btn-deladd' id='btn-cast'>CAST MEMBERS</button>
      <button type='button' class='btn-deladd' id='btn-extras'>EXTRAS</button>
      <button type='button' class='btn-deladd' id='btn-props'>PROPS</button>
      <button type='button' class='btn-deladd' id='btn-dressing'>SET DRESSING</button>
      <button type='button' class='btn-deladd' id='btn-costumes'>COSTUMES</button>
      <button type='button' class='btn-deladd' id='btn-makeup'>MAKEUP</button>
      <button type='button' class='btn-deladd' id='btn-vehicles'>VEHICLES</button>
      <button type='button' class='btn-deladd' id='btn-stunts'>STUNTS</button>
      <button type='button' class='btn-deladd' id='btn-sfx'>SPECIAL EFFECTS</button>
      <button type='button' class='btn-deladd' id='btn-livestock'>LIVESTOCK</button>
      <button type='button' class='btn-deladd' id='btn-handler'>ANIMAL HANDLER</button>
      <button type='button' class='btn-deladd' id='btn-music'>MUSIC</button>
      <button type='button' class='btn-deladd' id='btn-sounds'>SOUNDS</button>
      <button type='button' class='btn-deladd' id='btn-greenery'>GREENERY</button>
      <button type='button' class='btn-deladd' id='btn-security'>SECURITY</button>
    </div>
    <div class='col-md-8' style='font-size: 75%;' id='scriptArea'>
      <p id='scene'>Scene {{sceneNumber}}</p>
      <div id='display'>
        {% for i in range(0, doc.length) -%}
          {% if doc[i][0] !== 'NARRATOR' %}
            <p class='character'>{{doc[i][0]}}</p>
          {% endif %}
          {% if doc[i][0] !== 'NARRATOR'%}
            <p class='speech'>{{doc[i][1]}}</p>
          {% else %}
            <p class='action'>{{doc[i][1]}}</p>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class='col-md-2' style='background: white;'></div>
  </div>
  <script src='../js/parent.js'></script>
  <script src='../js/breakdown.js'></script>
{% endblock %}